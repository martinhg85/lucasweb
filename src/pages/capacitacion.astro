---
import Layout from "../layouts/Layout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ContactCTA from "../components/ContactCTA.astro";

const items = [
  "Capacitaciones in company sobre los riesgos específicos de tu actividad",
  "Coaching y formación personalizada en puestos estratégicos",
  "Planes anuales de capacitación en Seguridad Laboral y Salud Ocupacional",
  "Conferencias y talleres en instituciones nacionales e internacionales",
];
---

<Layout
  title="Capacitación"
  description="Capacitaciones en Seguridad e Higiene Laboral: in company, planes anuales y conferencias. Equipo de profesionales especializados por área."
>
  <section class="bg-white py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle
        as="h1"
        title="Capacitación"
        subtitle="Diseñamos y dictamos capacitaciones a medida del rubro y los riesgos reales del puesto. Sin clases enlatadas."
      />

      <div class="max-w-3xl mx-auto text-center space-y-6">
        {items.map((t, i) => (
          <>
            <p class="text-ink-700 text-base sm:text-lg leading-relaxed">{t}</p>
            {i < items.length - 1 && (
              <div class="mx-auto h-px w-2/3 border-t border-dashed border-ink-300"></div>
            )}
          </>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA
    title="¿NECESITÁS UNA CAPACITACIÓN A MEDIDA?"
    subtitle="Armamos el plan según el rubro, los riesgos y la cantidad de personal. Te respondemos a la brevedad."
  />
</Layout>
