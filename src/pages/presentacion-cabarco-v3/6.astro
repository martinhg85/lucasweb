---
import PresentacionLayout from "../../layouts/PresentacionLayout.astro";
import { clients } from "../../data/site";

// Filtramos CABARCO de la lista: no tiene sentido mostrársela como cliente
// a la propia CABARCO en una propuesta dirigida a ellos.
const clientesParaMostrar = clients.filter(
  (c) => c.name.toLowerCase() !== "cabarco"
);
---

<PresentacionLayout
  title="Clientes"
  pageNum={6}
  pageTotal={6}
  basePath="/presentacion-cabarco-v3"
  navLabel="CHWORK · CABARCO · V3"
>
  <div class="slide">
    <div class="pattern"></div>

    <div class="slide-header">
      <p class="caption-orange">Clientes</p>
      <p class="caption">06 / 06</p>
    </div>

    <div style="position:absolute; top:108px; left:80px; right:80px;">
      <h2 class="h2">Algunos de nuestros clientes</h2>
      <span class="rule" style="margin-top:16px;"></span>
    </div>

    <!-- Grid de logos en flex con wrap — última fila incompleta queda centrada -->
    <div style="position:absolute; top:260px; bottom:104px; left:80px; right:80px; display:flex; flex-wrap:wrap; justify-content:center; gap:20px; align-content:flex-start;">
      {clientesParaMostrar.map((c) => (
        <div style="flex:0 0 calc((100% - 40px) / 3); display:flex; align-items:center; justify-content:center; height:120px; padding:18px 28px; border:1px solid var(--ink-200); background:white;">
          {c.logo ? (
            <img
              src={c.logo}
              alt={c.name}
              style={`max-width:100%; width:auto; opacity:0.95; max-height:${c.aspect === "square" ? "84px" : "72px"};`}
              loading="eager"
            />
          ) : (
            <span style="font-size:13px; color:var(--ink-500); font-weight:600; text-align:center;">{c.name}</span>
          )}
        </div>
      ))}
    </div>

    <div class="slide-footer">
      <span>CHWORK — Asesoría integral en seguridad e higiene del trabajo</span>
      <span>CABA y Provincia de Buenos Aires · chwork.com.ar</span>
    </div>
  </div>
</PresentacionLayout>
