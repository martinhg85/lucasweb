---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Página no encontrada" noindex={true}>
  <section class="container-tight py-32 text-center">
    <p class="text-xs font-semibold tracking-widest uppercase text-brand-600 mb-3">404</p>
    <h1 class="font-display text-5xl font-extrabold text-ink-900">Esta página no existe</h1>
    <p class="mt-4 text-ink-500">Tal vez se movió o el enlace está roto.</p>
    <a href="/" class="inline-flex items-center gap-2 mt-8 px-6 py-3 rounded-full bg-ink-900 text-white font-semibold hover:bg-brand-600 transition-colors">
      Volver al inicio
    </a>
  </section>
</Layout>
