---
import Layout from "../../layouts/Layout.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import ServiceTabs from "../../components/ServiceTabs.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import { Icon } from "astro-icon/components";
import { services, whatsappUrl } from "../../data/site";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: service.title,
  description: service.description,
  provider: {
    "@type": "Organization",
    name: "chwork",
    url: "https://chwork.com.ar",
  },
  areaServed: ["Ciudad Autónoma de Buenos Aires", "Gran Buenos Aires"],
};
---

<Layout
  title={service.title}
  description={`${service.short} Servicio profesional en CABA y Provincia de Buenos Aires por chwork.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} slot="default" />

  <section class="py-16 sm:py-20 bg-white">
    <div class="container-tight">
      <nav class="text-xs text-ink-400 mb-8 tracking-wider uppercase">
        <a href="/" class="hover:text-orange-600">Inicio</a>
        <span class="mx-2">/</span>
        <a href="/servicios" class="hover:text-orange-600">Servicios</a>
        <span class="mx-2">/</span>
        <span class="text-navy-700">{service.title}</span>
      </nav>
    </div>

    <SectionTitle title={service.title} subtitle={service.description} />
    <ServiceTabs active={service.slug} />
  </section>

  <section class="bg-ink-50 py-16 sm:py-20">
    <div class="container-tight max-w-4xl">
      <h3 class="font-display text-xl sm:text-2xl font-bold tracking-wide uppercase text-navy-700 text-center mb-8">
        Qué incluye
      </h3>
      <ul class="grid gap-3 sm:grid-cols-2 max-w-3xl mx-auto">
        {service.items.map((it) => (
          <li class="flex items-start gap-3 p-4 bg-white border border-ink-200">
            <span class="mt-1 inline-block w-2 h-2 bg-orange-600 flex-shrink-0"></span>
            <span class="text-ink-700">{it}</span>
          </li>
        ))}
      </ul>

      {service.iconCards && service.iconCards.length > 0 && (
        <div class="max-w-4xl mx-auto mt-16">
          <h3 class="font-display text-xl sm:text-2xl font-bold tracking-wide uppercase text-navy-700 text-center mb-10">
            Matafuegos certificados — venta, mantenimiento y recarga
          </h3>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-ink-200 border border-ink-200">
            {service.iconCards.map((c) => (
              <div class="flex flex-col items-center text-center gap-4 bg-white px-6 py-10">
                <Icon name={c.icon} class="w-10 h-10 text-orange-600" />
                <p class="text-ink-700 leading-relaxed" set:html={c.text} />
              </div>
            ))}
          </div>
        </div>
      )}

      {service.regulations && service.regulations.length > 0 && (
        <div class="max-w-3xl mx-auto mt-10 p-6 bg-white border border-ink-200">
          <p class="text-[10px] font-bold tracking-[0.22em] uppercase text-orange-600 mb-3">
            Normativa de referencia
          </p>
          <ul class="flex flex-wrap gap-x-5 gap-y-2 text-sm text-ink-700">
            {service.regulations.map((r) => (
              <li class="flex items-center gap-2">
                <span class="inline-block w-1.5 h-1.5 bg-navy-700" aria-hidden="true"></span>
                <span class="font-medium">{r}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="text-center mt-12">
        <a
          href={whatsappUrl(`Hola, les consulto por: ${service.title}`)}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-8 py-3 bg-orange-600 text-white font-bold text-sm tracking-wider uppercase hover:bg-orange-700 transition-colors"
        >
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <ContactCTA />
</Layout>
