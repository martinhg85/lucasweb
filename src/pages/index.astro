---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ServiceTabs from "../components/ServiceTabs.astro";
import ClientGrid from "../components/ClientGrid.astro";
import ContactCTA from "../components/ContactCTA.astro";
import HowIWork from "../components/HowIWork.astro";
import RegulatoryStrip from "../components/RegulatoryStrip.astro";
import Stats from "../components/Stats.astro";
import { Icon } from "astro-icon/components";

const pillars = [
  {
    icon: "ph:users-three-bold",
    title: "Equipo especializado",
    text: "Licenciados y Técnicos en Higiene y Seguridad Laboral, cada uno especializado en un área: mediciones, ergonomía, primeros auxilios, peritaje e incendio.",
  },
  {
    icon: "ph:map-pin-area-bold",
    title: "Cobertura completa",
    text: "Trabajamos en CABA y Provincia de Buenos Aires. Acompañamos trámites ante GCBA, AGC, Bomberos y la SRT en ambas jurisdicciones.",
  },
  {
    icon: "ph:gauge-bold",
    title: "Mediciones interpretadas",
    text: "Instrumental propio calibrado y un compromiso simple: el protocolo no se entrega solo. Te explicamos qué dice y qué hay que corregir antes de la inspección.",
  },
];
---

<Layout
  title="Habilitaciones, mediciones y matafuegos en CABA y Buenos Aires"
  description="chwork — Asesoría integral en Seguridad e Higiene del Trabajo en CABA y Provincia de Buenos Aires: habilitaciones (Ley 5.920), mediciones ambientales SRT 84/12 y 85/12, recarga de matafuegos certificados IRAM, sistemas contra incendio, ergonomía y peritaje."
>
  <Hero
    eyebrow="Higiene y Seguridad en el Trabajo"
    title="Prevención y administración para comercios, industrias y consorcios"
    subtitle="Especialistas en servicios para CABA y Provincia de Buenos Aires. Equipo de Licenciados y Técnicos especializados por área."
  />

  <RegulatoryStrip />

  <Stats />

  <!-- NOSOTROS -->
  <section id="nosotros" class="bg-white py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle
        title="Por qué chwork"
        subtitle="Equipo especializado, conocimiento integral de la materia y un servicio que se adapta a la estructura de cada cliente."
      />

      <div class="grid gap-10 md:grid-cols-3 max-w-5xl mx-auto mt-4">
        {pillars.map((b) => (
          <div class="text-center">
            <div class="mx-auto mb-6 w-20 h-20 text-navy-700 relative grid place-items-center">
              <Icon name={b.icon} class="w-16 h-16" />
              <span class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full bg-orange-600/15 -z-10"></span>
            </div>
            <h3 class="font-display text-base font-bold tracking-wider uppercase text-navy-700 mb-3">
              {b.title}
            </h3>
            <p class="text-ink-500 text-sm leading-relaxed">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios" class="bg-ink-50 py-20 sm:py-24">
    <SectionTitle
      title="Servicios"
      subtitle="Áreas de trabajo y normativa de referencia. Elegí el área para ver el desglose completo."
    />
    <ServiceTabs />
  </section>

  <!-- CÓMO TRABAJO -->
  <HowIWork />

  <!-- CAPACITACIÓN -->
  <section id="capacitacion" class="bg-ink-50 py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle
        title="Capacitación"
        subtitle="Diseñamos y dictamos capacitaciones a medida del rubro y los riesgos reales del puesto. Sin clases enlatadas."
      />

      <div class="max-w-3xl mx-auto text-center space-y-6">
        {[
          "Capacitaciones en planta sobre los riesgos específicos de tu actividad",
          "Coaching y formación personalizada en puestos estratégicos",
          "Planes anuales de capacitación en Seguridad Laboral y Salud Ocupacional",
          "Conferencias y talleres en instituciones nacionales e internacionales",
        ].map((t, i, arr) => (
          <>
            <p class="text-ink-700 text-base sm:text-lg">{t}</p>
            {i < arr.length - 1 && (
              <div class="mx-auto h-px w-2/3 border-t border-dashed border-ink-300"></div>
            )}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- CLIENTES -->
  <section id="clientes" class="bg-white py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle
        title="Clientes"
        subtitle="Comercios, oficinas, gastronomía y obras civiles que confían en nuestro equipo."
        withRule={false}
      />
      <div class="mt-10">
        <ClientGrid />
      </div>
    </div>
  </section>

  <ContactCTA />
</Layout>
