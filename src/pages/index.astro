---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ServiceTabs from "../components/ServiceTabs.astro";
import ClientGrid from "../components/ClientGrid.astro";
import ContactCTA from "../components/ContactCTA.astro";
import HowIWork from "../components/HowIWork.astro";
import RegulatoryStrip from "../components/RegulatoryStrip.astro";
import Stats from "../components/Stats.astro";
import { Icon } from "astro-icon/components";

const pillars = [
  {
    icon: "ph:user-focus-bold",
    title: "Asesoramiento profesional",
    text: "Diseño cada propuesta a medida del rubro y los riesgos reales del puesto. Cada caso lo trabajo de principio a fin: del diagnóstico a la presentación.",
  },
  {
    icon: "ph:certificate-bold",
    title: "Doble matrícula",
    text: "Licenciado en Higiene y Seguridad en el Trabajo (UNLZ), con matrícula vigente en COPIME (CABA) y CPSH (Provincia de Buenos Aires).",
  },
  {
    icon: "ph:gauge-bold",
    title: "Mediciones interpretadas",
    text: "Trabajo con instrumental propio calibrado. Cada protocolo viene con su lectura técnica y plan de corrección, no solo el papel.",
  },
];
---

<Layout
  title="Asesoramiento en Seguridad e Higiene en CABA"
  description="Asesoramiento en Higiene y Seguridad en el Trabajo en CABA y Provincia de Buenos Aires. Habilitaciones bajo Ley 5.920, mediciones SRT 84/12 y 85/12, sistemas contra incendio. Lic. Lucas Contreras, doble matrícula COPIME (CABA) y CPSH (PBA)."
>
  <Hero
    eyebrow="Lic. en Higiene y Seguridad en el Trabajo"
    title="Habilitaciones, mediciones y sistemas contra incendio en CABA y Provincia"
    subtitle="Acompaño a comercios, oficinas y obras civiles a estar en regla con la Ley 19.587, el Decreto 351/79 y la Ley 5.920 CABA. Asesoría con doble matrícula vigente (COPIME y CPSH)."
    bottomLabel="SERVICIOS"
  />

  <RegulatoryStrip />

  <Stats />

  <!-- NOSOTROS -->
  <section id="nosotros" class="bg-white py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle
        title="Por qué trabajar conmigo"
        subtitle="Trato directo, decisiones rápidas y un solo responsable de cada caso, de principio a fin."
      />

      <div class="grid gap-10 md:grid-cols-3 max-w-5xl mx-auto mt-4">
        {pillars.map((b) => (
          <div class="text-center">
            <div class="mx-auto mb-6 w-20 h-20 text-navy-700 relative grid place-items-center">
              <Icon name={b.icon} class="w-16 h-16" />
              <span class="absolute -bottom-1 -right-1 w-8 h-8 rounded-full bg-orange-600/15 -z-10"></span>
            </div>
            <h3 class="font-display text-base font-bold tracking-wider uppercase text-navy-700 mb-3">
              {b.title}
            </h3>
            <p class="text-ink-500 text-sm leading-relaxed">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios" class="bg-ink-50 py-20 sm:py-24">
    <SectionTitle
      title="Servicios"
      subtitle="Tres áreas de trabajo, una sola firma. Elegí el área para ver el desglose y la normativa de referencia."
    />
    <ServiceTabs />
  </section>

  <!-- CÓMO TRABAJO -->
  <HowIWork />

  <!-- CAPACITACIÓN -->
  <section id="capacitacion" class="bg-ink-50 py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle
        title="Capacitación"
        subtitle="Diseño y dicto capacitaciones a medida del rubro y los riesgos reales del puesto. Sin clases enlatadas."
      />

      <div class="max-w-3xl mx-auto text-center space-y-6">
        {[
          "Capacitaciones en planta sobre los riesgos específicos de tu actividad",
          "Coaching y formación personalizada en puestos estratégicos",
          "Planes anuales de capacitación en Seguridad Laboral y Salud Ocupacional",
          "Conferencias y talleres en instituciones nacionales e internacionales",
        ].map((t, i, arr) => (
          <>
            <p class="text-ink-700 text-base sm:text-lg">{t}</p>
            {i < arr.length - 1 && (
              <div class="mx-auto h-px w-2/3 border-t border-dashed border-ink-300"></div>
            )}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- CLIENTES -->
  <section id="clientes" class="bg-white py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle
        title="Clientes"
        subtitle="Comercios, oficinas, gastronomía y obras civiles que confiaron en este servicio."
        withRule={false}
      />
      <div class="mt-10">
        <ClientGrid />
      </div>
    </div>
  </section>

  <ContactCTA />
</Layout>
