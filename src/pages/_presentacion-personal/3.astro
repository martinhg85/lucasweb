---
import PresentacionLayout from "../../layouts/PresentacionLayout.astro";
import { Icon } from "astro-icon/components";

const steps = [
  {
    icon: "ph:magnifying-glass-bold",
    num: "01",
    title: "Diagnóstico",
    body: "Hablo por WhatsApp o nos juntamos por videollamada. Reviso lo que ya tenés y te digo qué hace falta. Sin compromiso.",
  },
  {
    icon: "ph:hard-hat-bold",
    num: "02",
    title: "Visita técnica",
    body: "Voy yo al local u obra. Hago el relevamiento, las mediciones con instrumental propio y registro todo lo que hay que corregir.",
  },
  {
    icon: "ph:list-checks-bold",
    num: "03",
    title: "Plan de acción",
    body: "Te entrego un informe con prioridades, plazos y costos estimados. Decidís qué se ejecuta primero según riesgo y presupuesto.",
  },
  {
    icon: "ph:repeat-bold",
    num: "04",
    title: "Seguimiento",
    body: "Coordino las correcciones, presento los trámites y vuelvo a inspeccionar antes de la fiscalización oficial.",
  },
];
---

<PresentacionLayout title="Cómo trabajo" pageNum={3}>
  <div class="slide">
    <div class="pattern"></div>

    <div class="slide-header">
      <p class="caption-orange">Proceso</p>
      <p class="caption">03 / 05</p>
    </div>

    <div style="position:absolute; top:108px; left:80px; right:80px;">
      <h2 class="h2">Cómo trabajo en 4 pasos</h2>
      <span class="rule" style="margin-top:16px;"></span>
    </div>

    <div style="position:absolute; top:240px; bottom:104px; left:80px; right:80px; display:grid; grid-template-columns:repeat(4, 1fr); gap:24px;">
      {steps.map((s) => (
        <div style="display:flex; flex-direction:column; gap:18px;">
          <div style="display:flex; align-items:center; gap:14px;">
            <div style="width:56px; height:56px; background:var(--navy-700); color:white; display:grid; place-items:center; border-radius:6px;">
              <Icon name={s.icon} style="width:28px; height:28px;" />
            </div>
            <span style="font-size:24px; font-weight:900; color:var(--orange-600); line-height:1;">{s.num}</span>
          </div>
          <h3 class="h3">{s.title}</h3>
          <p class="body">{s.body}</p>
        </div>
      ))}
    </div>

    <div class="slide-footer">
      <span>Lic. Lucas Contreras — Higiene y Seguridad en el Trabajo</span>
      <span>COPIME L003619 · CPSH LHS-007573</span>
    </div>
  </div>
</PresentacionLayout>
