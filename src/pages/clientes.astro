---
import Layout from "../layouts/Layout.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ClientGrid from "../components/ClientGrid.astro";
import ContactCTA from "../components/ContactCTA.astro";
---

<Layout
  title="Clientes"
  description="Empresas que confían en chwork para su asesoramiento profesional en Seguridad e Higiene del Trabajo."
>
  <section class="bg-white py-20 sm:py-24">
    <div class="container-tight">
      <SectionTitle as="h1" title="Clientes" subtitle="Confían en nosotros." />
      <div class="mt-12 max-w-6xl mx-auto">
        <ClientGrid />
      </div>
    </div>
  </section>

  <ContactCTA />
</Layout>
