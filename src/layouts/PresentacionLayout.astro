---
// Layout para slides de presentación tipo licitación.
// Cada slide es una "página A4 landscape" con dimensiones físicas exactas:
//   297mm × 210mm
// El layout fuerza esas dimensiones tanto en pantalla como en print.
// Para exportar a PDF: imprimir desde Chrome con margins=none, scale=100%.

interface Props {
  title?: string;
  pageNum?: number;
  pageTotal?: number;
  // Permite reutilizar el layout para distintas presentaciones (chwork, cabarco, etc.).
  basePath?: string;
  navLabel?: string;
}

const {
  title,
  pageNum,
  pageTotal = 5,
  basePath = "/presentacion",
  navLabel = "chwork · presentación",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} — chwork` : "chwork — Presentación"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --navy-700: #1b2868;
        --navy-800: #15205a;
        --navy-900: #0f1849;
        --orange-500: #ee6a26;
        --orange-600: #e8602c;
        --ink-900: #1a1a1a;
        --ink-700: #444444;
        --ink-500: #6b6b6b;
        --ink-300: #c8c8c8;
        --ink-200: #e3e3e3;
        --ink-100: #f1f1f1;
        --ink-50: #f7f7f7;

        /* Aliases con prefix --color-* para componentes compartidos del
           sitio (Logo.astro y otros) que esperan estos nombres. */
        --color-navy-700: #1b2868;
        --color-navy-800: #15205a;
        --color-navy-900: #0f1849;
        --color-orange-500: #ee6a26;
        --color-orange-600: #e8602c;
        --color-ink-700: #444444;
        --color-ink-500: #6b6b6b;
        --color-ink-200: #e3e3e3;
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        font-family: "Open Sans", system-ui, sans-serif;
        color: var(--ink-700);
        background: #ddd;
        -webkit-font-smoothing: antialiased;
      }

      @page {
        size: A4 landscape;
        margin: 0;
      }

      .slide {
        width: 297mm;
        height: 210mm;
        background: white;
        position: relative;
        overflow: hidden;
        margin: 24px auto;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
      }

      @media print {
        html,
        body {
          background: white;
        }
        .slide {
          margin: 0;
          box-shadow: none;
          page-break-after: always;
        }
        .slide:last-child {
          page-break-after: auto;
        }
        .nav-controls {
          display: none !important;
        }
      }

      /* Patrón diagonal sutil */
      .pattern {
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
          135deg,
          rgba(0, 0, 0, 0.025) 0,
          rgba(0, 0, 0, 0.025) 1px,
          transparent 1px,
          transparent 10px
        );
        pointer-events: none;
      }

      /* ───── Type system ───── */

      .display {
        font-weight: 900;
        font-size: 72px;
        letter-spacing: -0.015em;
        line-height: 1;
        color: var(--navy-700);
        text-transform: uppercase;
      }

      .h1 {
        font-weight: 800;
        font-size: 48px;
        line-height: 1.05;
        letter-spacing: 0.005em;
        text-transform: uppercase;
        color: var(--navy-700);
      }

      .h2 {
        font-weight: 800;
        font-size: 32px;
        line-height: 1.1;
        text-transform: uppercase;
        color: var(--navy-700);
        letter-spacing: 0.005em;
      }

      .h3 {
        font-weight: 800;
        font-size: 18px;
        line-height: 1.2;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        color: var(--navy-700);
      }

      .lead {
        font-size: 20px;
        line-height: 1.5;
        color: var(--ink-700);
      }

      .body {
        font-size: 14px;
        line-height: 1.55;
        color: var(--ink-700);
      }

      .caption {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--ink-500);
      }

      .caption-orange {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--orange-600);
      }

      .micro {
        font-size: 11px;
        color: var(--ink-500);
      }

      /* ───── Componentes ───── */

      .rule {
        display: block;
        width: 64px;
        height: 3px;
        background: var(--orange-600);
      }

      .divider {
        height: 1px;
        background: var(--ink-200);
        border: none;
      }

      /* Frame fijo: 64px vertical, 80px horizontal */
      .frame {
        position: absolute;
        inset: 0;
        padding: 64px 80px;
      }

      /* Header del slide (eyebrow + page number) */
      .slide-header {
        position: absolute;
        top: 64px;
        left: 80px;
        right: 80px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }

      /* Footer del slide (chwork + matriculas) */
      .slide-footer {
        position: absolute;
        bottom: 48px;
        left: 80px;
        right: 80px;
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        color: var(--ink-500);
        border-top: 1px solid var(--ink-200);
        padding-top: 14px;
      }

      /* Brand unit (logo + name + tag) */
      .brand-unit {
        display: flex;
        align-items: center;
        gap: 20px;
      }
      .brand-unit .brand-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
        line-height: 1;
      }
      .brand-name {
        font-weight: 900;
        font-size: 56px;
        letter-spacing: -0.015em;
        line-height: 1;
        color: var(--navy-700);
        text-transform: uppercase;
      }
      .brand-tag {
        margin-top: 10px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--orange-600);
      }

      /* Nav controls (solo pantalla) */
      .nav-controls {
        position: fixed;
        top: 12px;
        left: 50%;
        transform: translateX(-50%);
        background: white;
        border: 1px solid var(--ink-200);
        border-radius: 999px;
        padding: 6px 16px;
        display: flex;
        gap: 12px;
        align-items: center;
        font-size: 12px;
        z-index: 100;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
      }
      .nav-controls a {
        color: var(--navy-700);
        text-decoration: none;
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 600;
      }
      .nav-controls a:hover {
        background: var(--ink-100);
      }
      .nav-controls a.active {
        background: var(--navy-700);
        color: white;
      }
      .nav-controls .label {
        color: var(--ink-500);
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }
    </style>
  </head>
  <body>
    {pageNum && (
      <nav class="nav-controls">
        <span class="label">{navLabel}</span>
        {Array.from({ length: pageTotal }, (_, i) => i + 1).map((n) => (
          <a href={`${basePath}/${n}`} class={n === pageNum ? "active" : ""}>{n}</a>
        ))}
      </nav>
    )}
    <slot />
  </body>
</html>
