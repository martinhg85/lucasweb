---
// Servicios como typography list estilo Studio.
// Reemplaza ServiceTabs en la home moderna.
import { services } from "../data/site";
---

<section class="bg-cream-50 py-20 sm:py-28 border-t border-ink-200">
  <div class="container-tight">
    <div class="grid md:grid-cols-[auto_1fr] gap-10 md:gap-20 mb-12">
      <div class="max-w-md">
        <p class="section-eyebrow mb-4">Servicios</p>
        <h2
          class="font-display font-light text-[clamp(2rem,4vw,3rem)] leading-[1.05] text-ink-900 tracking-tight"
        >
          Tres áreas, una sola firma.
        </h2>
      </div>
      <p class="text-ink-500 leading-relaxed text-lg max-w-2xl md:self-end">
        Te acompaño en el cumplimiento normativo de punta a punta — desde el primer relevamiento hasta la firma del protocolo. Atención personal en CABA y GBA.
      </p>
    </div>

    <ol class="divide-y divide-ink-200 border-y border-ink-200">
      {services.map((s, i) => (
        <li>
          <a
            href={`/servicios/${s.slug}`}
            class="group block py-8 sm:py-10 transition-colors hover:bg-ink-50 -mx-6 px-6 rounded-lg"
          >
            <div class="grid grid-cols-1 md:grid-cols-[80px_1fr_auto] items-baseline gap-4 md:gap-10">
              <p class="font-display text-3xl sm:text-4xl font-light text-accent-600 tracking-tight">
                {String(i + 1).padStart(2, "0")}
              </p>

              <div>
                <h3 class="font-display text-2xl sm:text-3xl text-ink-900 font-light tracking-tight leading-tight">
                  {s.title}
                </h3>
                <p class="mt-3 text-ink-500 leading-relaxed max-w-2xl">
                  {s.short}
                </p>

                {s.regulations && s.regulations.length > 0 && (
                  <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-1 text-xs text-ink-400">
                    {s.regulations.slice(0, 3).map((r) => (
                      <li class="flex items-center gap-1.5">
                        <span class="inline-block w-1 h-1 bg-ink-400" aria-hidden="true"></span>
                        <span>{r}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </div>

              <span class="text-sm font-semibold text-ink-700 group-hover:text-accent-600 transition-colors whitespace-nowrap">
                Ver detalle →
              </span>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>
