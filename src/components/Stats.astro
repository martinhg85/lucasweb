---
import { site } from "../data/site";
---

<section class="bg-cream-100 border-y border-ink-200">
  <div class="container-tight py-12 sm:py-16">
    <ul class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-12 reveal-stagger">
      {site.stats.map((s, i) => (
        <li class="text-left">
          <p class="num-badge text-[11px] tracking-[0.18em] uppercase mb-3">
            {String(i + 1).padStart(3, "0")}
          </p>
          <p class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold tracking-tight text-ink-900">
            {s.value}
          </p>
          <div class="mt-4 h-px w-12 bg-copper-500"></div>
          <p class="mt-3 text-xs font-medium tracking-[0.12em] uppercase text-ink-500">
            {s.label}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
