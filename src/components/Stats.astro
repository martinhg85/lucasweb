---
import { site } from "../data/site";
---

<section class="bg-white border-y border-ink-100">
  <div class="container-tight py-12 sm:py-16">
    <ul class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-12 text-center reveal-stagger">
      {site.stats.map((s) => (
        <li>
          <p class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-ink-900">
            {s.value}
          </p>
          <div class="mx-auto mt-4 h-1 w-10 rounded-full bg-sky-500"></div>
          <p class="mt-3 text-xs font-semibold tracking-[0.18em] uppercase text-ink-500">
            {s.label}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
