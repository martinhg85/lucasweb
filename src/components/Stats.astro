---
import { site } from "../data/site";
---

<section class="relative bg-night-900 border-y border-white/5 overflow-hidden">
  <div class="container-tight py-12 sm:py-16">
    <ul class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-12 reveal-stagger">
      {site.stats.map((s) => (
        <li class="text-left">
          <p class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight text-ink-50">
            {s.value}
          </p>
          <div class="mt-4 h-0.5 w-12 rounded-full bg-orange-500"></div>
          <p class="mt-3 text-xs font-semibold tracking-[0.18em] uppercase text-ink-400">
            {s.label}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
