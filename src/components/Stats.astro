---
import { site } from "../data/site";
---

<section class="bg-ink-50 border-y border-ink-200">
  <div class="container-tight py-10 sm:py-12">
    <ul class="grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-10 text-center">
      {site.stats.map((s) => (
        <li>
          <p class="font-display text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide text-navy-700">
            {s.value}
          </p>
          <div class="mx-auto mt-3 h-px w-10 bg-orange-600"></div>
          <p class="mt-3 text-[11px] sm:text-xs font-semibold tracking-[0.18em] uppercase text-ink-500">
            {s.label}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
