---
import { site, services, mailtoUrl, whatsappUrl } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="bg-cream-100 border-t border-ink-200">
  <div class="container-tight py-16 sm:py-20">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3">
          <span
            class="grid place-items-center w-11 h-11 rounded-md border border-olive-700 bg-cream-50 text-olive-700 font-display text-base font-semibold"
          >
            L·C
          </span>
          <p class="font-display text-xl font-semibold tracking-tight text-ink-900">
            Lucas Contreras
          </p>
        </div>
        <p class="mt-5 text-ink-500 text-sm max-w-sm leading-relaxed">
          {site.tagline}. Atención personal en {site.coverage.extended}.
        </p>
        <p class="mt-3 text-ink-400 text-xs">
          {site.professional.matriculas.map((m) => `${m.colegio} ${m.numero}`).join(" · ")}
        </p>
      </div>

      <div>
        <p class="text-xs font-semibold tracking-widest uppercase text-olive-700 mb-5">
          Servicios
        </p>
        <ul class="space-y-3 text-sm text-ink-700">
          {services.map((s) => (
            <li>
              <a
                href={`/servicios/${s.slug}`}
                class="hover:text-olive-700 transition-colors"
              >
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-xs font-semibold tracking-widest uppercase text-olive-700 mb-5">
          Contacto
        </p>
        <ul class="space-y-3 text-sm text-ink-700">
          <li>
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="hover:text-olive-700 transition-colors"
            >
              {site.contact.phoneDisplay}
            </a>
          </li>
          <li>
            <a
              href={mailtoUrl()}
              class="hover:text-olive-700 transition-colors break-all"
            >
              {site.contact.email}
            </a>
          </li>
          <li class="text-ink-400">{site.coverage.extended}</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-ink-200">
    <div
      class="container-tight py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-ink-500"
    >
      <p>© {year} {site.professional.fullName}. Todos los derechos reservados.</p>
      <p>Buenos Aires, Argentina</p>
    </div>
  </div>
</footer>
