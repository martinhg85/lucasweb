---
import { site, services, mailtoUrl, whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";
const year = new Date().getFullYear();
---

<footer class="bg-night-950 border-t border-white/5">
  <div class="container-tight py-16 sm:py-20">
    <div class="grid gap-12 md:grid-cols-[1.4fr_1fr_1fr]">
      <div>
        <div class="flex items-center gap-3">
          <span
            class="grid place-items-center w-12 h-12 rounded-2xl bg-gradient-to-br from-orange-500 to-orange-600 text-white shadow-lg shadow-orange-500/40"
          >
            <Icon name="ph:hard-hat-bold" class="w-6 h-6" />
          </span>
          <p class="font-bold text-xl tracking-tight text-ink-50">Lucas Contreras</p>
        </div>
        <p class="mt-5 text-ink-400 text-sm max-w-sm leading-relaxed">
          {site.tagline}. Atención personal en {site.coverage.extended}.
        </p>
        <p class="mt-3 text-ink-500 text-xs">{site.professional.matricula}</p>
      </div>

      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-orange-400 mb-5">
          Servicios
        </p>
        <ul class="space-y-3 text-sm text-ink-300">
          {services.map((s) => (
            <li>
              <a
                href={`/servicios/${s.slug}`}
                class="hover:text-orange-400 transition-colors"
              >
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-orange-400 mb-5">
          Contacto
        </p>
        <ul class="space-y-3 text-sm text-ink-300">
          <li>
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="hover:text-orange-400 transition-colors"
            >
              {site.contact.phoneDisplay}
            </a>
          </li>
          <li>
            <a
              href={mailtoUrl()}
              class="hover:text-orange-400 transition-colors break-all"
            >
              {site.contact.email}
            </a>
          </li>
          <li class="text-ink-500">{site.coverage.extended}</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/5">
    <div
      class="container-tight py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-ink-500"
    >
      <p>© {year} {site.professional.fullName}. Todos los derechos reservados.</p>
      <p>Buenos Aires, Argentina</p>
    </div>
  </div>
</footer>
