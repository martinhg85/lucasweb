---
import { howIWork } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Cómo trabajo.",
  subtitle = "Mismo método para cada cliente. Cuatro pasos, todos atendidos por mí.",
} = Astro.props;
---

<section class="relative bg-night-800 py-24 sm:py-32 overflow-hidden border-y border-white/5">
  <span
    class="orb orb-amber w-[28rem] h-[28rem]"
    style="top:50%; left:30%; opacity:0.18;"
    aria-hidden="true"
  ></span>

  <div class="container-tight relative">
    <div class="max-w-2xl mb-16 reveal">
      <p class="section-eyebrow mb-5">Proceso</p>
      <h2
        class="font-display font-bold text-ink-50 leading-[0.95] tracking-tight"
        style="font-size: clamp(2.5rem, 5.5vw, 4.5rem);"
      >
        {title}
      </h2>
      <p class="mt-6 text-lg text-ink-400 max-w-xl">{subtitle}</p>
    </div>

    <ol class="grid gap-5 md:grid-cols-2 lg:grid-cols-4 reveal-stagger">
      {howIWork.map((step, i) => (
        <li
          class="relative bg-night-900/60 border border-white/10 rounded-2xl p-7 hover:border-accent-500/40 transition-colors group"
        >
          <div class="flex items-baseline gap-3 mb-6">
            <p
              class="font-display font-bold text-accent-500 tracking-tight leading-none glow-amber"
              style="font-size: clamp(2.5rem, 4vw, 4rem);"
            >
              {String(i + 1).padStart(2, "0")}
            </p>
            <span
              class="grid place-items-center w-9 h-9 rounded-full bg-night-700 text-ink-200 ring-1 ring-white/10 group-hover:bg-accent-500/15 group-hover:text-accent-500 group-hover:ring-accent-500/30 transition-colors"
            >
              <Icon name={step.icon} class="w-4 h-4" />
            </span>
          </div>
          <h3 class="font-display text-xl text-ink-50 font-bold tracking-tight leading-tight">
            {step.title}
          </h3>
          <p class="mt-3 text-sm text-ink-400 leading-relaxed">{step.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
