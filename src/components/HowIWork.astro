---
import { howIWork } from "../data/site";
import { Icon } from "astro-icon/components";
import SectionTitle from "./SectionTitle.astro";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Cómo trabajo",
  subtitle = "Mismo método para cada cliente. Cuatro pasos, todos atendidos por mí.",
} = Astro.props;
---

<section class="bg-white py-20 sm:py-28">
  <div class="container-tight">
    <SectionTitle eyebrow="Proceso" title={title} subtitle={subtitle} />

    <!-- Timeline vertical estilo HISE -->
    <ol class="relative max-w-3xl mx-auto reveal-stagger">
      <!-- Línea vertical detrás de los dots -->
      <span
        class="absolute left-[19px] sm:left-6 top-2 bottom-2 w-px bg-gradient-to-b from-sky-400 via-sky-200 to-transparent"
        aria-hidden="true"
      ></span>

      {howIWork.map((step, i) => (
        <li class="relative pl-14 sm:pl-20 pb-10 last:pb-0">
          <!-- Dot numerado -->
          <span
            class="absolute left-0 top-0 grid place-items-center w-10 sm:w-12 h-10 sm:h-12 rounded-full bg-sky-500 text-white font-bold text-base ring-4 ring-sky-50 shadow-lg shadow-sky-500/20"
          >
            {String(i + 1).padStart(2, "0")}
          </span>

          <div class="card-soft p-6 sm:p-7">
            <div class="flex items-start gap-4">
              <span class="grid place-items-center w-10 h-10 rounded-full bg-sky-50 text-sky-600 flex-shrink-0">
                <Icon name={step.icon} class="w-5 h-5" />
              </span>
              <div>
                <h3 class="font-bold text-ink-900 text-lg leading-tight">
                  {step.title}
                </h3>
                <p class="mt-2 text-sm text-ink-500 leading-relaxed">
                  {step.text}
                </p>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
