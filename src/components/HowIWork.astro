---
import { howIWork } from "../data/site";
import { Icon } from "astro-icon/components";
import SectionTitle from "./SectionTitle.astro";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Cómo trabajo",
  subtitle = "Mismo método para cada cliente. Cuatro pasos, todos atendidos por mí.",
} = Astro.props;
---

<section class="relative bg-night-800 py-24 sm:py-32 overflow-hidden border-y border-white/5">
  <span
    class="absolute top-1/2 left-1/3 w-[24rem] h-[24rem] glow-orange opacity-30"
    aria-hidden="true"
  ></span>

  <div class="container-tight relative">
    <SectionTitle eyebrow="Proceso" title={title} subtitle={subtitle} />

    <ol class="grid gap-5 md:grid-cols-2 lg:grid-cols-4 reveal-stagger">
      {howIWork.map((step, i) => (
        <li class="card-dark p-7 group">
          <div class="flex items-baseline gap-3 mb-5">
            <p
              class="font-display font-extrabold text-orange-500 tracking-tight leading-none"
              style="font-size: clamp(2.5rem, 4vw, 3.5rem); text-shadow: 0 0 28px rgba(249,115,22,0.45);"
            >
              {String(i + 1).padStart(2, "0")}
            </p>
            <span
              class="grid place-items-center w-9 h-9 rounded-xl bg-night-700 text-ink-200 ring-1 ring-white/10 group-hover:bg-orange-500/15 group-hover:text-orange-400 group-hover:ring-orange-500/30 transition-colors"
            >
              <Icon name={step.icon} class="w-4 h-4" />
            </span>
          </div>
          <h3 class="font-display font-bold text-ink-50 text-lg leading-tight">
            {step.title}
          </h3>
          <p class="mt-3 text-sm text-ink-400 leading-relaxed">{step.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
