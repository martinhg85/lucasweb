---
import { howIWork } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Cómo trabajo.",
  subtitle = "Mismo método para cada cliente. Cuatro pasos, todos atendidos por mí.",
} = Astro.props;
---

<section class="bg-cream-100 py-20 sm:py-28 border-t border-ink-200">
  <div class="container-tight">
    <div class="max-w-2xl mb-14">
      <p class="section-eyebrow mb-4">Proceso</p>
      <h2
        class="font-display font-light text-[clamp(2rem,4vw,3rem)] leading-[1.05] text-ink-900 tracking-tight"
      >
        {title}
      </h2>
      <p class="mt-5 text-ink-500 leading-relaxed">{subtitle}</p>
    </div>

    <ol class="grid gap-8 md:grid-cols-4">
      {howIWork.map((step, i) => (
        <li class="relative">
          <div class="flex items-baseline gap-3 mb-5">
            <p
              class="font-display text-5xl font-light text-accent-600 tracking-tight leading-none"
            >
              {String(i + 1).padStart(2, "0")}
            </p>
            <span class="grid place-items-center w-8 h-8 rounded-full bg-cream-50 border border-ink-200 text-ink-700">
              <Icon name={step.icon} class="w-4 h-4" />
            </span>
          </div>
          <h3 class="font-display text-2xl text-ink-900 font-medium tracking-tight leading-tight">
            {step.title}
          </h3>
          <p class="mt-3 text-sm text-ink-500 leading-relaxed">{step.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
