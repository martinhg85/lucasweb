---
import { howIWork } from "../data/site";
import { Icon } from "astro-icon/components";
import SectionTitle from "./SectionTitle.astro";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Cómo trabajo",
  subtitle = "Mismo método para cada cliente. Cuatro pasos, todos atendidos por mí.",
} = Astro.props;
---

<section class="bg-cream-100 py-24 sm:py-32 border-y border-ink-200">
  <div class="container-tight">
    <SectionTitle eyebrow="Proceso" title={title} subtitle={subtitle} />

    <ol class="grid gap-5 md:grid-cols-2 lg:grid-cols-4 reveal-stagger">
      {howIWork.map((step, i) => (
        <li class="card-frame p-7 group">
          <div class="flex items-baseline justify-between mb-6">
            <p class="num-badge text-2xl font-semibold tracking-tight">
              {String(i + 1).padStart(3, "0")}
            </p>
            <span class="grid place-items-center w-9 h-9 rounded-md bg-olive-50 text-olive-700 ring-1 ring-olive-100 group-hover:bg-olive-700 group-hover:text-cream-50 transition-colors">
              <Icon name={step.icon} class="w-4 h-4" />
            </span>
          </div>
          <h3 class="font-display text-lg font-semibold text-ink-900 leading-tight tracking-tight">
            {step.title}
          </h3>
          <p class="mt-3 text-sm text-ink-500 leading-relaxed">{step.text}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
