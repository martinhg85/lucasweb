---
import { whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";
---

<a
  href={whatsappUrl()}
  target="_blank"
  rel="noopener"
  aria-label="Escribir por WhatsApp"
  class="fixed bottom-5 right-5 z-50 inline-grid place-items-center w-14 h-14 rounded-full bg-[#25D366] text-white shadow-lg shadow-[#25D366]/30 hover:scale-105 transition-transform"
>
  <Icon name="ph:whatsapp-logo-fill" class="w-8 h-8" aria-hidden="true" />
</a>
