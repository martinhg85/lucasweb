---
import { whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";
---

<a
  href={whatsappUrl()}
  target="_blank"
  rel="noopener"
  aria-label="Escribir por WhatsApp"
  class="fixed bottom-5 right-5 z-50 inline-grid place-items-center w-14 h-14 rounded-full bg-[#25D366] text-white shadow-2xl shadow-[#25D366]/40 hover:scale-110 transition-transform ring-2 ring-[#25D366]/30"
>
  <Icon name="ph:whatsapp-logo-fill" class="w-7 h-7" aria-hidden="true" />
  <span
    class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-20 -z-10"
    aria-hidden="true"
  ></span>
</a>
