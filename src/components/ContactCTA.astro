---
import { whatsappUrl, mailtoUrl, site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "¿Necesitás asesoramiento?",
  subtitle = "Coordinemos una visita o videollamada para evaluar tu caso, sin compromiso.",
} = Astro.props;
---

<section class="relative bg-gradient-to-br from-sky-500 via-sky-500 to-sky-600 text-white overflow-hidden">
  <span
    class="absolute -top-24 -right-24 w-[28rem] h-[28rem] rounded-full bg-white/10 blur-3xl pointer-events-none"
    aria-hidden="true"
  ></span>
  <span
    class="absolute -bottom-24 -left-24 w-[24rem] h-[24rem] rounded-full bg-amber-400/15 blur-3xl pointer-events-none"
    aria-hidden="true"
  ></span>

  <div class="container-tight py-20 sm:py-28 relative">
    <div class="grid md:grid-cols-[1.2fr_1fr] gap-12 md:gap-16 items-center">
      <div class="reveal">
        <p
          class="inline-block text-[10px] font-bold tracking-[0.22em] uppercase bg-white/15 text-white px-3 py-1 rounded-full mb-5"
        >
          Contacto directo
        </p>
        <h2
          class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.1] tracking-tight"
        >
          {title}
        </h2>
        <p class="mt-6 text-white/90 text-base sm:text-lg leading-relaxed max-w-xl">
          {subtitle}
        </p>
      </div>

      <div class="space-y-3 reveal">
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="group flex items-center justify-between gap-4 p-5 rounded-2xl bg-white text-ink-900 hover:shadow-xl shadow-lg transition-all"
        >
          <div class="flex items-center gap-4 min-w-0">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-[#25D366]/15 text-[#25D366] flex-shrink-0">
              <Icon name="ph:whatsapp-logo-bold" class="w-6 h-6" />
            </span>
            <div class="min-w-0">
              <p class="text-[10px] font-bold tracking-widest uppercase text-ink-400">
                WhatsApp
              </p>
              <p class="font-bold text-base mt-0.5 truncate">
                {site.contact.phoneDisplay}
              </p>
            </div>
          </div>
          <span class="text-ink-400 group-hover:text-sky-600 group-hover:translate-x-1 transition-all flex-shrink-0">→</span>
        </a>

        <a
          href={mailtoUrl()}
          class="group flex items-center justify-between gap-4 p-5 rounded-2xl bg-white/10 border border-white/30 text-white hover:bg-white/20 transition-all"
        >
          <div class="flex items-center gap-4 min-w-0">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-white/15 flex-shrink-0">
              <Icon name="ph:envelope-simple-bold" class="w-6 h-6" />
            </span>
            <div class="min-w-0">
              <p class="text-[10px] font-bold tracking-widest uppercase text-white/60">
                Mail
              </p>
              <p class="font-bold text-base mt-0.5 truncate">
                {site.contact.email}
              </p>
            </div>
          </div>
          <span class="text-white/60 group-hover:translate-x-1 transition-transform flex-shrink-0">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
