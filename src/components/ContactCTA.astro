---
import { whatsappUrl, mailtoUrl, site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "¿Necesitás asesoramiento?",
  subtitle = "Te respondo personalmente. Coordinemos una visita o videollamada para evaluar tu caso, sin compromiso.",
} = Astro.props;
---

<section class="relative bg-night-900 text-ink-50 overflow-hidden border-t border-white/5">
  <span
    class="absolute -top-24 left-1/2 -translate-x-1/2 w-[44rem] h-[44rem] glow-orange opacity-50"
    aria-hidden="true"
  ></span>
  <div class="absolute inset-0 pattern-diagonal pointer-events-none"></div>

  <div class="container-tight py-20 sm:py-28 relative">
    <div class="grid md:grid-cols-[1.2fr_1fr] gap-12 md:gap-16 items-center">
      <div class="reveal">
        <p
          class="inline-block text-[10px] font-bold tracking-[0.22em] uppercase text-orange-400 bg-orange-500/10 border border-orange-500/20 px-3 py-1 rounded-full mb-5"
        >
          Contacto directo
        </p>
        <h2
          class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold uppercase leading-[1.05] tracking-tight"
        >
          {title}
        </h2>
        <p class="mt-6 text-ink-300 text-base sm:text-lg leading-relaxed max-w-xl">
          {subtitle}
        </p>
      </div>

      <div class="space-y-3 reveal">
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="group flex items-center justify-between gap-4 p-5 rounded-2xl card-dark"
        >
          <div class="flex items-center gap-4 min-w-0">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-[#25D366]/15 text-[#25D366] flex-shrink-0 ring-1 ring-[#25D366]/30">
              <Icon name="ph:whatsapp-logo-bold" class="w-6 h-6" />
            </span>
            <div class="min-w-0">
              <p class="text-[10px] font-bold tracking-widest uppercase text-ink-400">
                WhatsApp
              </p>
              <p class="font-bold text-base text-ink-50 mt-0.5 truncate">
                {site.contact.phoneDisplay}
              </p>
            </div>
          </div>
          <span class="text-orange-400 group-hover:translate-x-1 transition-transform flex-shrink-0">→</span>
        </a>

        <a
          href={mailtoUrl()}
          class="group flex items-center justify-between gap-4 p-5 rounded-2xl card-dark"
        >
          <div class="flex items-center gap-4 min-w-0">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-orange-500/15 text-orange-400 flex-shrink-0 ring-1 ring-orange-500/30">
              <Icon name="ph:envelope-simple-bold" class="w-6 h-6" />
            </span>
            <div class="min-w-0">
              <p class="text-[10px] font-bold tracking-widest uppercase text-ink-400">
                Mail
              </p>
              <p class="font-bold text-base text-ink-50 mt-0.5 truncate">
                {site.contact.email}
              </p>
            </div>
          </div>
          <span class="text-orange-400 group-hover:translate-x-1 transition-transform flex-shrink-0">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
