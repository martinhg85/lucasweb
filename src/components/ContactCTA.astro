---
import { whatsappUrl, mailtoUrl, site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Contame qué necesitás.",
  subtitle = "Te respondo personalmente. Coordinemos una visita o videollamada para evaluar tu caso, sin compromiso.",
} = Astro.props;
---

<section class="bg-ink-900 text-cream-50 relative overflow-hidden">
  <div
    class="absolute inset-0 opacity-[0.04]"
    style="background-image: radial-gradient(circle at 20% 50%, white 1px, transparent 1px); background-size: 40px 40px;"
    aria-hidden="true"
  ></div>

  <div class="container-tight py-20 sm:py-28 relative">
    <div class="grid md:grid-cols-[1.2fr_1fr] gap-12 md:gap-20 items-center">
      <div>
        <p class="section-eyebrow text-accent-500 mb-5">Hablemos</p>
        <h2
          class="font-display font-light text-[clamp(2.25rem,5vw,4rem)] leading-[1.02] tracking-tight"
        >
          {title}
        </h2>
        <p class="mt-6 text-cream-100/80 text-lg leading-relaxed max-w-xl">
          {subtitle}
        </p>
      </div>

      <div class="space-y-4">
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="group flex items-center justify-between gap-4 p-6 rounded-xl bg-cream-50/5 border border-cream-50/10 hover:bg-cream-50/10 hover:border-cream-50/30 transition-all"
        >
          <div class="flex items-center gap-4">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-[#25D366]/15 text-[#25D366]">
              <Icon name="ph:whatsapp-logo-bold" class="w-6 h-6" />
            </span>
            <div>
              <p class="text-xs uppercase tracking-widest text-cream-100/60 font-medium">
                WhatsApp
              </p>
              <p class="font-display text-xl mt-1 tracking-tight">
                {site.contact.phoneDisplay}
              </p>
            </div>
          </div>
          <span class="text-cream-50/60 group-hover:text-cream-50 transition-colors">→</span>
        </a>

        <a
          href={mailtoUrl()}
          class="group flex items-center justify-between gap-4 p-6 rounded-xl bg-cream-50/5 border border-cream-50/10 hover:bg-cream-50/10 hover:border-cream-50/30 transition-all"
        >
          <div class="flex items-center gap-4">
            <span class="grid place-items-center w-12 h-12 rounded-full bg-accent-500/15 text-accent-500">
              <Icon name="ph:envelope-simple-bold" class="w-6 h-6" />
            </span>
            <div>
              <p class="text-xs uppercase tracking-widest text-cream-100/60 font-medium">
                Mail
              </p>
              <p class="font-display text-lg mt-1 tracking-tight break-all">
                {site.contact.email}
              </p>
            </div>
          </div>
          <span class="text-cream-50/60 group-hover:text-cream-50 transition-colors">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
