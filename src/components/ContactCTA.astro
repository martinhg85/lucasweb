---
import { whatsappUrl, mailtoUrl, site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Hablemos.",
  subtitle = "Te respondo personalmente. Coordinemos una visita o videollamada para evaluar tu caso, sin compromiso.",
} = Astro.props;
---

<section
  class="relative bg-night-900 text-ink-50 overflow-hidden border-t border-white/5"
>
  <span
    class="orb orb-amber w-[44rem] h-[44rem]"
    style="top:-12rem; left:50%; transform:translateX(-50%); opacity:0.35;"
    aria-hidden="true"
  ></span>
  <div
    class="absolute inset-0 pattern-diagonal opacity-50 pointer-events-none"
  ></div>

  <div class="container-tight py-24 sm:py-32 relative">
    <div class="max-w-4xl mx-auto text-center reveal">
      <p class="section-eyebrow mb-6">Contacto</p>
      <h2
        class="font-display font-bold text-ink-50 leading-[0.92] tracking-[-0.04em] glow-amber"
        style="font-size: clamp(3rem, 9vw, 8rem);"
      >
        {title}
      </h2>
      <p class="mt-8 text-ink-300 text-lg leading-relaxed max-w-2xl mx-auto">
        {subtitle}
      </p>

      <div
        class="mt-12 flex flex-wrap justify-center gap-3 reveal"
        style="transition-delay: 0.2s;"
      >
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="btn-neon"
        >
          <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4" />
          WhatsApp · {site.contact.phoneDisplay}
        </a>
        <a href={mailtoUrl()} class="btn-ghost">
          <Icon name="ph:envelope-simple-bold" class="w-4 h-4" />
          {site.contact.email}
        </a>
      </div>
    </div>
  </div>
</section>
