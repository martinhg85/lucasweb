---
import { whatsappUrl, mailtoUrl, site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Hablemos sobre tu caso",
  subtitle = "Coordinemos una visita o videollamada para evaluar tu caso, sin compromiso.",
} = Astro.props;
---

<section class="relative bg-olive-700 text-cream-50 overflow-hidden">
  <span
    class="absolute -bottom-32 -right-24 w-[32rem] h-[32rem] rounded-full bg-copper-500/20 blur-3xl pointer-events-none"
    aria-hidden="true"
  ></span>

  <div class="container-tight py-20 sm:py-28 relative">
    <div class="grid md:grid-cols-[1.2fr_1fr] gap-12 md:gap-16 items-center">
      <div class="reveal">
        <p class="inline-flex items-center gap-2 text-[11px] font-semibold tracking-[0.22em] uppercase text-copper-300 mb-5">
          <span class="inline-block w-6 h-px bg-copper-500"></span>
          Contacto directo
        </p>
        <h2
          class="font-display text-3xl sm:text-4xl md:text-5xl font-semibold leading-[1.05] tracking-[-0.025em]"
        >
          {title}
        </h2>
        <p class="mt-6 text-cream-100/85 text-base sm:text-lg leading-relaxed max-w-xl">
          {subtitle}
        </p>
      </div>

      <div class="space-y-3 reveal">
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="group flex items-center justify-between gap-4 p-5 rounded-md bg-cream-50 text-ink-900 hover:bg-white shadow-md transition-all"
        >
          <div class="flex items-center gap-4 min-w-0">
            <span class="grid place-items-center w-12 h-12 rounded-md bg-olive-50 text-olive-700 flex-shrink-0">
              <Icon name="ph:whatsapp-logo-bold" class="w-6 h-6" />
            </span>
            <div class="min-w-0">
              <p class="text-[10px] font-semibold tracking-widest uppercase text-ink-400">
                WhatsApp
              </p>
              <p class="font-semibold text-base mt-0.5 truncate">
                {site.contact.phoneDisplay}
              </p>
            </div>
          </div>
          <span class="text-copper-500 group-hover:translate-x-1 transition-transform flex-shrink-0">→</span>
        </a>

        <a
          href={mailtoUrl()}
          class="group flex items-center justify-between gap-4 p-5 rounded-md bg-cream-50/10 border border-cream-50/25 text-cream-50 hover:bg-cream-50/15 transition-all"
        >
          <div class="flex items-center gap-4 min-w-0">
            <span class="grid place-items-center w-12 h-12 rounded-md bg-cream-50/10 flex-shrink-0">
              <Icon name="ph:envelope-simple-bold" class="w-6 h-6" />
            </span>
            <div class="min-w-0">
              <p class="text-[10px] font-semibold tracking-widest uppercase text-cream-100/65">
                Mail
              </p>
              <p class="font-semibold text-base mt-0.5 truncate">
                {site.contact.email}
              </p>
            </div>
          </div>
          <span class="text-cream-100/65 group-hover:translate-x-1 transition-transform flex-shrink-0">→</span>
        </a>
      </div>
    </div>
  </div>
</section>
