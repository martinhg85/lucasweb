---
import { whatsappUrl, mailtoUrl, site } from "../data/site";

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "¿NECESITÁS ASESORAMIENTO?",
  subtitle = "Coordinemos una visita o videollamada para evaluar tu caso, sin compromiso. Te responde el matriculado.",
} = Astro.props;
---

<section class="bg-navy-700 text-white relative overflow-hidden">
  <div class="absolute inset-0 pattern-diagonal-light opacity-50"></div>
  <div class="container-tight py-16 sm:py-20 relative">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="font-display text-2xl sm:text-3xl md:text-4xl font-light tracking-widest uppercase">
        {title}
      </h2>
      <div class="mx-auto mt-6 h-px w-32 bg-orange-500"></div>
      <p class="mt-6 text-white/80 text-base sm:text-lg leading-relaxed">
        {subtitle}
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a
          href={whatsappUrl()}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-3 bg-orange-600 text-white font-bold text-sm tracking-wider uppercase hover:bg-orange-700 transition-colors"
        >
          WhatsApp · {site.contact.phoneDisplay}
        </a>
        <a
          href={mailtoUrl()}
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/40 text-white font-bold text-sm tracking-wider uppercase hover:border-white hover:bg-white/10 transition-colors"
        >
          {site.contact.email}
        </a>
      </div>
    </div>
  </div>
</section>
