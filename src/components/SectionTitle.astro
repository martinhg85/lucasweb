---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  withRule?: boolean;
  align?: "left" | "center";
}

const {
  eyebrow,
  title,
  subtitle,
  withRule = false,
  align = "center",
} = Astro.props;
const wrapperAlign = align === "center" ? "text-center mx-auto" : "text-left";
---

<div class:list={["mb-12 sm:mb-16 max-w-3xl reveal", wrapperAlign]}>
  {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
  <h2
    class="font-display text-[clamp(1.875rem,4vw,2.75rem)] font-extrabold text-ink-900 leading-[1.15] tracking-tight"
  >
    {title}
  </h2>
  {subtitle && (
    <p
      class:list={[
        "mt-5 text-ink-500 text-base sm:text-lg leading-relaxed max-w-2xl",
        align === "center" && "mx-auto",
      ]}
    >
      {subtitle}
    </p>
  )}
  {withRule && (
    <div
      class:list={[
        "mt-8 h-px w-full max-w-xl bg-ink-200",
        align === "center" && "mx-auto",
      ]}
    ></div>
  )}
</div>
