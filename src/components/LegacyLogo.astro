// industrial. Si en algún momento se quiere restaurar este logo, importar este
// componente y reemplazar el <span class="header-logo ..."> del Header.
---

<span
  class="header-logo relative inline-grid place-items-center rounded-full border-[3px] border-navy-700 flex-shrink-0"
>
  <span class="absolute inset-1.5 rounded-full bg-ink-200"></span>
  <span class="relative w-3 h-3 rounded-full bg-orange-600 -translate-y-0.5"></span>
  <span class="absolute bottom-1.5 w-7 h-1.5 bg-navy-700 rounded-sm"></span>
</span>
