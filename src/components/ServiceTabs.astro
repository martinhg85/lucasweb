---
import { services } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  active?: string;
}

const { active = services[0].slug } = Astro.props;
const activeService = services.find((s) => s.slug === active) ?? services[0];

const icons: Record<string, string> = {
  habilitaciones: "ph:buildings-bold",
  mediciones: "ph:gauge-bold",
  incendios: "ph:fire-bold",
  matafuegos: "ph:fire-extinguisher-bold",
  capacitacion: "ph:graduation-cap-bold",
};
---

<div class="container-tight">
  <!-- Pills -->
  <div class="flex flex-wrap justify-center gap-2 sm:gap-3 mb-12">
    {services.map((s) => (
      <a
        href={`/servicios/${s.slug}`}
        class:list={[
          "inline-block px-4 sm:px-5 py-2 text-[11px] sm:text-xs font-bold tracking-widest uppercase border transition-colors rounded-full",
          s.slug === activeService.slug
            ? "border-navy-700 bg-navy-700 text-white"
            : "border-ink-300 text-navy-700 hover:border-navy-700",
        ]}
      >
        {s.title}
      </a>
    ))}
  </div>

  <!-- Servicio activo: icono + lista -->
  <div class="grid md:grid-cols-[200px_1fr] gap-8 md:gap-12 items-start max-w-5xl mx-auto pb-8">
    <div class="flex justify-center md:justify-start">
      <div class="w-32 h-32 sm:w-40 sm:h-40 text-navy-700 relative grid place-items-center">
        <Icon name={icons[activeService.slug] ?? icons.habilitaciones} class="w-28 h-28 sm:w-32 sm:h-32" />
        <span class="absolute -bottom-2 -right-2 w-12 h-12 rounded-full bg-orange-600/15 -z-10"></span>
      </div>
    </div>

    <div class="border-l-0 md:border-l-2 md:border-navy-700 md:pl-8">
      <h3 class="font-display text-xl sm:text-2xl font-bold tracking-wide uppercase text-navy-700 mb-4">
        {activeService.title}
      </h3>

      <p class="text-ink-500 text-sm leading-relaxed mb-5">
        {activeService.description}
      </p>

      <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-2 text-ink-700">
        {activeService.items.map((it) => (
          <li class="flex gap-2">
            <span class="text-orange-600 font-bold flex-shrink-0">—</span>
            <span class="text-sm">{it}</span>
          </li>
        ))}
      </ul>

      {activeService.regulations && activeService.regulations.length > 0 && (
        <div class="mt-7 pt-5 border-t border-ink-200">
          <p class="text-[10px] font-bold tracking-[0.22em] uppercase text-orange-600 mb-3">
            Normativa de referencia
          </p>
          <ul class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-ink-700">
            {activeService.regulations.map((r) => (
              <li class="flex items-center gap-2">
                <span class="inline-block w-1 h-1 bg-navy-700" aria-hidden="true"></span>
                <span class="font-medium">{r}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </div>
</div>
