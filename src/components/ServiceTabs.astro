---
import { services } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  active?: string;
}

const { active = services[0].slug } = Astro.props;
const activeService = services.find((s) => s.slug === active) ?? services[0];

const icons: Record<string, string> = {
  habilitaciones: "ph:buildings-bold",
  mediciones: "ph:gauge-bold",
  incendios: "ph:fire-extinguisher-bold",
  capacitacion: "ph:graduation-cap-bold",
};
---

<div class="container-tight">
  <!-- Pills -->
  <div class="flex flex-wrap justify-center gap-2 mb-12 reveal">
    {services.map((s) => (
      <a
        href={`/servicios/${s.slug}`}
        class:list={[
          "inline-block px-5 py-2.5 text-xs font-bold tracking-wide uppercase rounded-full transition-all",
          s.slug === activeService.slug
            ? "bg-sky-500 text-white shadow-lg shadow-sky-500/25"
            : "bg-white text-ink-700 border border-ink-200 hover:border-sky-400 hover:text-sky-600",
        ]}
      >
        {s.title}
      </a>
    ))}
  </div>

  <!-- Servicio activo -->
  <div class="card-soft p-7 sm:p-10 max-w-5xl mx-auto reveal">
    <div class="grid md:grid-cols-[auto_1fr] gap-8 md:gap-10 items-start">
      <div class="grid place-items-center w-20 h-20 sm:w-24 sm:h-24 rounded-2xl bg-sky-50 text-sky-600 flex-shrink-0">
        <Icon
          name={icons[activeService.slug] ?? icons.habilitaciones}
          class="w-12 h-12 sm:w-14 sm:h-14"
        />
      </div>

      <div>
        <h3 class="font-bold text-ink-900 text-xl sm:text-2xl leading-tight">
          {activeService.title}
        </h3>
        <p class="mt-3 text-ink-500 text-sm sm:text-base leading-relaxed">
          {activeService.description}
        </p>

        <ul class="mt-6 grid sm:grid-cols-2 gap-x-6 gap-y-2.5 text-sm text-ink-700">
          {activeService.items.map((it) => (
            <li class="flex items-start gap-2">
              <Icon
                name="ph:check-circle-fill"
                class="w-4 h-4 text-sky-500 mt-0.5 flex-shrink-0"
                aria-hidden="true"
              />
              <span>{it}</span>
            </li>
          ))}
        </ul>

        {activeService.regulations && activeService.regulations.length > 0 && (
          <div class="mt-7 pt-5 border-t border-ink-200">
            <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-sky-600 mb-3">
              Normativa de referencia
            </p>
            <ul class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-ink-700">
              {activeService.regulations.map((r) => (
                <li class="flex items-center gap-2">
                  <span
                    class="inline-block w-1 h-1 rounded-full bg-sky-500"
                    aria-hidden="true"
                  ></span>
                  <span class="font-medium">{r}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</div>
