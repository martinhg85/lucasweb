---
const cases = [
  {
    sector: "Gastronomía",
    title: "Habilitación de local en Palermo",
    metric: "[14 días]",
    metricLabel: "Plazo total ante AGC",
    note: "Plan de Autoprotección, plano de incendio y trámite ante AGC.",
  },
  {
    sector: "Industria",
    title: "Mediciones SRT en planta de [rubro]",
    metric: "[8 puestos]",
    metricLabel: "Iluminación + ruido + ergonomía",
    note: "Protocolos firmados con plan de mejoras priorizadas por riesgo.",
  },
  {
    sector: "Obra civil",
    title: "Permiso de obra para vivienda en [barrio]",
    metric: "[100%]",
    metricLabel: "Aprobado a la primera",
    note: "Coordinación entre arquitecto, propietario y GCBA.",
  },
];
---

<section class="relative bg-night-900 py-24 sm:py-32 overflow-hidden">
  <span
    class="orb orb-deep w-[30rem] h-[30rem]"
    style="bottom:0; left:-8rem; opacity:0.3;"
    aria-hidden="true"
  ></span>

  <div class="container-tight relative">
    <div
      class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16 reveal"
    >
      <div class="max-w-2xl">
        <p class="section-eyebrow mb-5">Casos seleccionados</p>
        <h2
          class="font-display font-bold text-ink-50 leading-[0.95] tracking-tight"
          style="font-size: clamp(2.5rem, 5.5vw, 4.5rem);"
        >
          Trabajo<br />
          <span class="text-accent-500">reciente.</span>
        </h2>
      </div>
      <a
        href="/contacto"
        class="text-sm font-semibold text-ink-200 hover:text-accent-400 transition-colors shrink-0"
      >
        Hablemos de tu caso →
      </a>
    </div>

    <ul class="grid md:grid-cols-3 gap-5 lg:gap-6 reveal-stagger">
      {cases.map((c) => (
        <li
          class="tilt-card group relative bg-night-800 border border-white/10 rounded-2xl overflow-hidden hover:border-white/20 transition-colors"
        >
          <span class="tilt-card-glow rounded-2xl"></span>

          <!-- Banner top con métrica gigante -->
          <div
            class="relative aspect-[5/4] overflow-hidden border-b border-white/10"
          >
            <div
              class="absolute inset-0 pattern-diagonal opacity-40 pointer-events-none"
            ></div>
            <span
              class="absolute -top-10 -right-10 w-44 h-44 rounded-full blur-3xl bg-accent-600/20 pointer-events-none"
              aria-hidden="true"
            ></span>

            <div
              class="absolute inset-0 grid place-items-center px-6"
            >
              <p
                class="font-display font-bold text-accent-500/80 leading-none tracking-tight glow-amber group-hover:scale-105 transition-transform duration-500"
                style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
              >
                {c.metric}
              </p>
            </div>

            <span class="absolute top-4 left-4 inline-block px-3 py-1 rounded-full bg-night-900/70 backdrop-blur-sm text-[10px] font-semibold tracking-widest uppercase text-ink-200 border border-white/10">
              {c.sector}
            </span>
          </div>

          <div class="relative p-6">
            <p class="font-display text-lg text-ink-50 font-bold leading-snug tracking-tight">
              {c.title}
            </p>
            <p class="mt-3 text-sm text-ink-400 leading-relaxed">{c.note}</p>
            <div class="mt-5 flex items-center gap-3 text-xs">
              <span class="text-accent-500 font-bold">{c.metric}</span>
              <span class="w-1 h-1 rounded-full bg-ink-500"></span>
              <span class="text-ink-500">{c.metricLabel}</span>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
