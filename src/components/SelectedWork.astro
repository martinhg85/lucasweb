---
// Selected work estilo Studio (Tailwind UI). 3 casos con métrica visible.
// Placeholders entre [corchetes] hasta que Lucas confirme casos reales.
const cases = [
  {
    sector: "Gastronomía",
    title: "Habilitación de local en Palermo",
    metric: "[14 días]",
    metricLabel: "Plazo total ante AGC",
    note: "Plan de Autoprotección, plano de incendio y trámite ante AGC.",
  },
  {
    sector: "Industria",
    title: "Mediciones SRT en planta de [rubro]",
    metric: "[8 puestos]",
    metricLabel: "Iluminación + ruido + ergonomía",
    note: "Protocolos firmados con plan de mejoras priorizadas por riesgo.",
  },
  {
    sector: "Obra civil",
    title: "Permiso de obra para vivienda en [barrio]",
    metric: "[100%]",
    metricLabel: "Aprobación en primera presentación",
    note: "Coordinación entre arquitecto, propietario y GCBA.",
  },
];
---

<section class="bg-cream-50 py-20 sm:py-28 border-t border-ink-200">
  <div class="container-tight">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-14">
      <div class="max-w-2xl">
        <p class="section-eyebrow mb-4">Casos seleccionados</p>
        <h2
          class="font-display font-light text-[clamp(2rem,4vw,3rem)] leading-[1.05] text-ink-900 tracking-tight"
        >
          Trabajo reciente.
        </h2>
        <p class="mt-5 text-ink-500 leading-relaxed">
          {/* TODO: reemplazar con casos reales (con autorización). */}
          Una muestra acotada del tipo de proyectos que acompaño. Si tu caso se parece a alguno, lo más rápido es escribirme.
        </p>
      </div>
      <a
        href="/contacto"
        class="text-sm font-semibold text-ink-800 link-underline shrink-0"
      >
        Hablemos de tu caso →
      </a>
    </div>

    <ul class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {cases.map((c) => (
        <li class="group relative bg-cream-100 rounded-lg overflow-hidden border border-ink-200/70 transition-all hover:border-ink-300 hover:-translate-y-0.5">
          <div class="aspect-[4/3] bg-gradient-to-br from-ink-100 to-cream-100 relative overflow-hidden">
            <div class="absolute inset-0 grid place-items-center">
              <p class="font-display text-5xl text-accent-600/30 font-light tracking-tight">
                {c.metric}
              </p>
            </div>
            <span class="absolute top-4 left-4 inline-block px-3 py-1 rounded-full bg-cream-50 text-[11px] font-semibold tracking-wide text-ink-700 border border-ink-200">
              {c.sector}
            </span>
          </div>
          <div class="p-6">
            <p class="font-display text-lg text-ink-900 font-medium leading-snug tracking-tight">
              {c.title}
            </p>
            <p class="mt-3 text-sm text-ink-500 leading-relaxed">{c.note}</p>
            <div class="mt-5 flex items-center gap-3 text-xs text-ink-700">
              <span class="font-semibold text-ink-900">{c.metric}</span>
              <span class="w-1 h-1 rounded-full bg-ink-400"></span>
              <span class="text-ink-500">{c.metricLabel}</span>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
