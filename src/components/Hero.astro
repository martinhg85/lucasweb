---
import { site, whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  bottomLabel?: string;
  showCTA?: boolean;
  showContact?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  showCTA = true,
  showContact = true,
} = Astro.props;
---

<section class="relative bg-gradient-to-br from-sky-50 via-white to-sky-50 overflow-hidden">
  <span
    class="absolute -top-32 -right-32 w-[36rem] h-[36rem] rounded-full bg-sky-100/60 blur-3xl pointer-events-none"
    aria-hidden="true"
  ></span>
  <span
    class="absolute -bottom-32 -left-32 w-[28rem] h-[28rem] rounded-full bg-amber-400/10 blur-3xl pointer-events-none"
    aria-hidden="true"
  ></span>

  <div class="relative container-tight pt-12 pb-16 sm:pt-20 sm:pb-24 md:pt-28 md:pb-32">
    <div class="grid lg:grid-cols-[1.15fr_1fr] gap-10 lg:gap-16 items-center">
      <!-- Texto -->
      <div class="max-w-2xl">
        <!-- Stars rating + label -->
        <div class="flex items-center gap-3 mb-7">
          <div class="flex items-center gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <Icon
                name="ph:star-fill"
                class="w-4 h-4 text-amber-400"
                aria-hidden="true"
              />
            ))}
          </div>
          <span class="text-sm font-semibold text-ink-700">
            Atención personalizada · 100% por mí
          </span>
        </div>

        {eyebrow && (
          <p class="text-xs font-bold tracking-[0.18em] uppercase text-sky-600 mb-4">
            {eyebrow}
          </p>
        )}

        {title && (
          <h1
            class="font-display text-4xl sm:text-5xl md:text-6xl font-extrabold text-ink-900 leading-[1.05] tracking-tight"
          >
            {title}
          </h1>
        )}

        {subtitle && (
          <p class="mt-6 text-ink-700 text-lg sm:text-xl leading-relaxed max-w-xl">
            {subtitle}
          </p>
        )}

        {showCTA && (
          <div class="mt-9 flex flex-wrap items-center gap-3">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="btn-primary"
            >
              <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4" />
              Solicitar asesoramiento
            </a>
            <a href="/servicios" class="btn-secondary">
              Ver servicios →
            </a>
          </div>
        )}

        <!-- Tagline 24h estilo HISE -->
        <div class="mt-7 flex items-center gap-2 text-sm text-ink-500">
          <span class="relative inline-flex w-2 h-2">
            <span class="absolute inset-0 rounded-full bg-emerald-500 animate-ping opacity-75"></span>
            <span class="relative rounded-full w-2 h-2 bg-emerald-500"></span>
          </span>
          <span class="font-medium">Respondo en menos de 4 horas</span>
        </div>
      </div>

      <!-- Card con foto a la derecha -->
      <div class="relative">
        <div
          class="relative rounded-[1.75rem] overflow-hidden bg-ink-200 aspect-[4/5] sm:aspect-[5/6] lg:aspect-[4/5] shadow-2xl shadow-sky-900/15 border border-white"
          style={`background-image: linear-gradient(180deg, transparent 55%, rgba(15,23,42,0.5) 100%), url('${site.professional.photo}'); background-size: cover; background-position: center;`}
          aria-label="Foto de Lucas Contreras"
        >
          <!-- Badge flotante: Lic. + nombre -->
          <div class="absolute bottom-5 left-5 right-5">
            <div class="bg-white/95 backdrop-blur-sm rounded-2xl px-4 py-3 shadow-lg shadow-sky-900/10 inline-block max-w-full">
              <p class="text-[10px] font-bold tracking-widest uppercase text-sky-600">
                Lic. en Seguridad e Higiene
              </p>
              <p class="text-sm font-bold text-ink-900 mt-0.5 leading-tight">
                {site.professional.fullName}
              </p>
            </div>
          </div>

          <!-- Chip "Disponible" -->
          <span
            class="absolute top-5 right-5 inline-flex items-center gap-1.5 px-3 py-1.5 bg-white rounded-full text-[11px] font-semibold text-ink-900 shadow-md"
          >
            <span class="relative inline-flex w-1.5 h-1.5">
              <span class="absolute inset-0 rounded-full bg-emerald-500 animate-ping opacity-75"></span>
              <span class="relative rounded-full w-1.5 h-1.5 bg-emerald-500"></span>
            </span>
            Disponible
          </span>
        </div>

        <!-- Floating contact card -->
        {showContact && (
          <div
            class="hidden md:flex absolute -bottom-5 -left-5 lg:-left-8 bg-white rounded-2xl shadow-xl shadow-sky-900/15 border border-ink-200 px-5 py-4 gap-3 items-center"
          >
            <span
              class="grid place-items-center w-10 h-10 rounded-full bg-sky-50 text-sky-600"
            >
              <Icon name="ph:phone-bold" class="w-5 h-5" />
            </span>
            <div>
              <p class="text-[10px] font-bold tracking-widest uppercase text-ink-400">
                WhatsApp
              </p>
              <p class="text-sm font-bold text-ink-900 leading-tight">
                {site.contact.phoneDisplay}
              </p>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
