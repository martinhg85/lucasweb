---
import { site, whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  bottomLabel?: string;
  showCTA?: boolean;
  showContact?: boolean;
}

const {
  eyebrow = "Asesor en Seguridad e Higiene · CABA",
  title,
  subtitle,
  showCTA = true,
} = Astro.props;
---

<section class="relative bg-cream-50 overflow-hidden">
  <div class="container-tight pt-12 pb-16 sm:pt-20 sm:pb-24 md:pt-28 md:pb-32">
    <div class="grid md:grid-cols-[1fr_auto] gap-10 md:gap-16 items-end">
      <!-- Texto -->
      <div class="max-w-3xl">
        {eyebrow && (
          <div class="flex items-center gap-3 mb-7">
            <span
              class="inline-block w-8 h-px bg-accent-600"
              aria-hidden="true"
            ></span>
            <p class="section-eyebrow">{eyebrow}</p>
          </div>
        )}

        {title && (
          <h1
            class="font-display text-[clamp(2.25rem,6vw,4.75rem)] leading-[1.02] text-ink-900 tracking-tight font-light"
          >
            {title}
          </h1>
        )}

        {subtitle && (
          <p class="mt-7 text-ink-700 text-lg sm:text-xl leading-relaxed max-w-xl">
            {subtitle}
          </p>
        )}

        {showCTA && (
          <div class="mt-10 flex flex-wrap items-center gap-x-8 gap-y-4">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-7 py-3.5 bg-ink-900 text-cream-50 text-sm font-semibold tracking-wide rounded-full hover:bg-accent-700 transition-colors"
            >
              <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4" />
              Hablemos por WhatsApp
            </a>
            <a
              href="/servicios"
              class="text-sm font-semibold text-ink-800 link-underline"
            >
              Ver servicios →
            </a>
          </div>
        )}
      </div>

      <!-- Foto compacta -->
      <div class="hidden md:block">
        <div class="relative">
          <div
            class="w-56 h-72 lg:w-64 lg:h-80 bg-ink-200 rounded-md overflow-hidden"
            style={`background-image: url('${site.professional.photo}'); background-size: cover; background-position: center;`}
            aria-label="Foto de Lucas Contreras"
          ></div>
          <span
            class="absolute -bottom-3 -left-3 w-20 h-20 rounded-full bg-accent-100 -z-10"
            aria-hidden="true"
          ></span>
          <span
            class="absolute -top-2 -right-2 inline-flex items-center gap-1.5 px-3 py-1 bg-cream-50 border border-ink-200 rounded-full text-[11px] font-semibold text-ink-700 shadow-sm"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            Disponible
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class="border-b border-ink-200"></div>
</section>
