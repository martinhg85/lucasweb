---
import { site, whatsappUrl, mailtoUrl } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  showCTA?: boolean;
  showContact?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  showCTA = true,
  showContact = true,
} = Astro.props;
---

<section class="relative bg-white overflow-hidden">
  <!-- Pattern diagonal sutil cubriendo toda la sección.
       Como la foto está encima, el pattern se ve solo donde no hay foto:
       todo el lado izquierdo + el espacio debajo de la foto al pie del hero. -->
  <div
    class="absolute inset-0 pattern-diagonal pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative container-tight pt-6 pb-12 sm:pt-8 sm:pb-16 md:pt-10 md:pb-20">
    <div class="grid md:grid-cols-[1.5fr_1fr] gap-10 md:gap-12 lg:gap-16 items-start">
      <!-- Texto -->
      <div class="max-w-2xl">
        {showContact && (
          <div class="mb-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-navy-700">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center gap-2 hover:text-orange-600 transition-colors"
              aria-label="Escribir por WhatsApp"
            >
              <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4 text-orange-600" />
              <span class="font-semibold tracking-wide">{site.contact.phoneDisplay}</span>
            </a>
            <span class="hidden sm:inline-block w-px h-4 bg-ink-300" aria-hidden="true"></span>
            <a
              href={mailtoUrl("Consulta desde la web")}
              class="group inline-flex items-center gap-2 hover:text-orange-600 transition-colors break-all"
              aria-label="Enviar mail"
            >
              <Icon name="ph:envelope-simple-bold" class="w-4 h-4 text-orange-600 flex-shrink-0" />
              <span class="font-semibold tracking-wide">{site.contact.email}</span>
            </a>
          </div>
        )}
        {eyebrow && (
          <p class="text-xs font-bold tracking-[0.22em] uppercase text-orange-600 mb-4">
            {eyebrow}
          </p>
        )}
        {title && (
          <h1 class="font-display text-2xl sm:text-3xl md:text-4xl font-extrabold tracking-wide uppercase text-navy-700 leading-[1.15]">
            {title}
          </h1>
        )}
        {subtitle && (
          <p class="mt-5 text-ink-500 text-base sm:text-lg max-w-md leading-relaxed">
            {subtitle}
          </p>
        )}

        {showCTA && (
          <div class="mt-8 flex gap-3">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="flex-1 sm:flex-initial inline-flex items-center justify-center gap-2 px-6 py-3 bg-orange-600 text-white font-bold text-sm tracking-wider uppercase hover:bg-orange-700 transition-colors"
            >
              Consultar
            </a>
            <a
              href="/servicios"
              class="flex-1 sm:flex-initial inline-flex items-center justify-center gap-2 px-6 py-3 border-2 border-navy-700 text-navy-700 font-bold text-sm tracking-wider uppercase hover:bg-navy-700 hover:text-white transition-colors"
            >
              Servicios
            </a>
          </div>
        )}

      </div>

      <!-- Card encuadrado con imagen genérica del rubro
           (banner industrial: instrumental, casco, clipboard, etc.).
           Para activar imagen: dropear /public/syh-banner.jpg
           (idealmente 1200×1500+, vertical 4:5) y descomentar la
           capa de fondo. Hasta que llegue, queda card vacío con
           bandas decorativas que sigue funcionando como hero. -->
      <div class="relative">
        <!-- Sombra naranja offset (efecto encuadrado) -->
        <div
          class="absolute -top-3 -right-3 w-full h-full bg-orange-600 -z-10"
          aria-hidden="true"
        ></div>

        <div
          class="relative aspect-[4/5] sm:aspect-[5/6] lg:aspect-[4/5] overflow-hidden bg-ink-100 border-2 border-navy-700"
          aria-label="Banner — Higiene y Seguridad en el Trabajo"
        >
          <!-- Imagen genérica del rubro -->
          <div
            class="absolute inset-0 bg-cover bg-center"
            style="background-image: linear-gradient(180deg, transparent 50%, rgba(15,24,73,0.35) 100%), url('/syh-banner-v.jpg'); background-position: center;"
            aria-hidden="true"
          ></div>

          <!-- Banda diagonal decorativa industrial superior izquierda -->
          <div
            class="absolute top-0 left-0 w-32 h-12 bg-navy-700/85"
            style="clip-path: polygon(0 0, 100% 0, 70% 100%, 0% 100%);"
            aria-hidden="true"
          ></div>

          <!-- Banda naranja decorativa inferior derecha -->
          <div
            class="absolute bottom-0 right-0 w-24 h-10 bg-orange-600/80"
            style="clip-path: polygon(30% 0, 100% 0, 100% 100%, 0% 100%);"
            aria-hidden="true"
          ></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Línea fina al pie del hero -->
  <div class="border-b border-ink-200"></div>
</section>
