---
import { site, whatsappUrl, mailtoUrl } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  bottomLabel?: string;
  showCTA?: boolean;
  showContact?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  bottomLabel = "SERVICIOS",
  showCTA = true,
  showContact = true,
} = Astro.props;
---

<section class="relative bg-white overflow-hidden">
  <!-- Pattern diagonal sutil cubriendo toda la sección.
       Como la foto está encima, el pattern se ve solo donde no hay foto:
       todo el lado izquierdo + el espacio debajo de la foto al pie del hero. -->
  <div
    class="absolute inset-0 pattern-diagonal pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative container-tight pt-6 pb-12 sm:pt-8 sm:pb-16 md:pt-10 md:pb-20">
    <div class="grid md:grid-cols-[1.5fr_1fr] gap-10 md:gap-12 lg:gap-16 items-center">
      <!-- Texto -->
      <div class="max-w-2xl">
        {showContact && (
          <div class="mb-8 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-navy-700">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center gap-2 hover:text-orange-600 transition-colors"
              aria-label="Escribir por WhatsApp"
            >
              <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4 text-orange-600" />
              <span class="font-semibold tracking-wide">{site.contact.phoneDisplay}</span>
            </a>
            <span class="hidden sm:inline-block w-px h-4 bg-ink-300" aria-hidden="true"></span>
            <a
              href={mailtoUrl("Consulta desde la web")}
              class="group inline-flex items-center gap-2 hover:text-orange-600 transition-colors break-all"
              aria-label="Enviar mail"
            >
              <Icon name="ph:envelope-simple-bold" class="w-4 h-4 text-orange-600 flex-shrink-0" />
              <span class="font-semibold tracking-wide">{site.contact.email}</span>
            </a>
          </div>
        )}
        {eyebrow && (
          <p class="text-xs font-bold tracking-[0.22em] uppercase text-orange-600 mb-4">
            {eyebrow}
          </p>
        )}
        {title && (
          <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-wide uppercase text-navy-700 leading-[1.15]">
            {title}
          </h1>
        )}
        {subtitle && (
          <p class="mt-5 text-ink-500 text-base sm:text-lg max-w-md leading-relaxed">
            {subtitle}
          </p>
        )}

        {showCTA && (
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-6 py-3 bg-orange-600 text-white font-bold text-sm tracking-wider uppercase hover:bg-orange-700 transition-colors"
            >
              Consultar
            </a>
            <a
              href="/servicios"
              class="inline-flex items-center gap-2 px-6 py-3 border-2 border-navy-700 text-navy-700 font-bold text-sm tracking-wider uppercase hover:bg-navy-700 hover:text-white transition-colors"
            >
              Servicios
            </a>
          </div>
        )}

        {bottomLabel && (
          <p class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-widest text-navy-700 mt-12">
            {bottomLabel}
          </p>
        )}
      </div>

      <!-- Foto encuadrada -->
      <div class="relative">
        <!-- Frame con bordes industriales: 2 capas decorativas -->
        <div
          class="absolute -top-3 -right-3 w-full h-full bg-orange-600 -z-10"
          aria-hidden="true"
        ></div>

        <div
          class="relative aspect-[4/5] sm:aspect-[5/6] lg:aspect-[4/5] overflow-hidden bg-ink-200 border-2 border-navy-700"
          style={`background-image: linear-gradient(180deg, transparent 50%, rgba(15,24,73,0.5) 100%), url('${site.professional.photo}'); background-size: cover; background-position: 57% 30%;`}
          aria-label="Foto de Lucas Contreras"
        >
          <!-- Banda diagonal decorativa industrial superior izquierda -->
          <div
            class="absolute top-0 left-0 w-32 h-12 bg-navy-700/85"
            style="clip-path: polygon(0 0, 100% 0, 70% 100%, 0% 100%);"
            aria-hidden="true"
          ></div>

          <!-- Chip "Disponible" arriba a la derecha -->
          <span
            class="absolute top-4 right-4 inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-ink-200 rounded-full text-[11px] font-semibold text-navy-700 shadow-md"
          >
            <span class="relative inline-flex w-1.5 h-1.5">
              <span class="absolute inset-0 rounded-full bg-emerald-500 animate-ping opacity-75"></span>
              <span class="relative rounded-full w-1.5 h-1.5 bg-emerald-500"></span>
            </span>
            Disponible
          </span>

          <!-- Badge inferior con título y nombre -->
          <div class="absolute bottom-4 left-4 right-4">
            <div class="bg-white/95 backdrop-blur-sm border border-navy-700/10 px-4 py-3 inline-block max-w-full">
              <p class="text-[10px] font-bold tracking-widest uppercase text-orange-600">
                Lic. en Seguridad e Higiene
              </p>
              <p class="text-sm font-extrabold tracking-tight text-navy-700 mt-0.5 leading-tight">
                {site.professional.fullName}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Línea fina al pie del hero -->
  <div class="border-b border-ink-200"></div>
</section>
