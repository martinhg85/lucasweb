---
import { site, whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  bottomLabel?: string;
  showCTA?: boolean;
  showContact?: boolean;
}

const {
  eyebrow = "Asesor en Seguridad e Higiene · CABA",
  showCTA = true,
} = Astro.props;

// Headline en palabras separadas para stagger animation
const headline = ["SEGURIDAD", "QUE NO", "SE NEGOCIA."];
---

<section class="relative bg-night-900 text-ink-50 overflow-hidden">
  <!-- Orbs de fondo -->
  <span
    class="orb orb-amber w-[40rem] h-[40rem]"
    style="top:-12rem; left:-10rem;"
    aria-hidden="true"
  ></span>
  <span
    class="orb orb-deep w-[28rem] h-[28rem]"
    style="bottom:-8rem; right:-6rem; animation-delay:-3s;"
    aria-hidden="true"
  ></span>

  <!-- Patrón diagonal sutil sobre todo -->
  <div class="absolute inset-0 pattern-diagonal pointer-events-none"></div>

  <div class="relative container-tight pt-16 pb-24 sm:pt-24 sm:pb-32 md:pt-28 md:pb-40">
    <div class="grid lg:grid-cols-[1fr_auto] gap-12 lg:gap-16 items-end">
      <div class="max-w-4xl">
        <!-- Eyebrow con dot pulsante -->
        <div class="flex items-center gap-3 mb-8">
          <span class="relative inline-flex w-2 h-2">
            <span
              class="absolute inset-0 rounded-full bg-accent-500 animate-ping opacity-75"
            ></span>
            <span class="relative rounded-full w-2 h-2 bg-accent-500"></span>
          </span>
          <p class="text-[11px] font-bold tracking-[0.22em] uppercase text-accent-400">
            {eyebrow}
          </p>
        </div>

        <!-- Headline GIGANTE con stagger -->
        <h1
          class="font-display word-rise font-bold leading-[0.92] tracking-[-0.04em] text-ink-50 glow-amber"
          style="font-size: clamp(3rem, 11vw, 9.5rem);"
        >
          {headline.map((word, i) => (
            <span class:list={[i === headline.length - 1 && "text-accent-500"]}>
              {word}{i < headline.length - 1 ? " " : ""}
            </span>
          ))}
        </h1>

        <!-- Subhead -->
        <p
          class="mt-10 max-w-xl text-base sm:text-lg text-ink-300 leading-relaxed reveal"
          style="transition-delay: 1.1s;"
        >
          Soy <span class="text-ink-50 font-semibold">Lucas Contreras</span>,
          Lic. en Seguridad e Higiene. Habilitaciones, mediciones e incendio en
          CABA — yo voy, yo mido, yo firmo.
        </p>

        {showCTA && (
          <div
            class="mt-10 flex flex-wrap items-center gap-3 reveal"
            style="transition-delay: 1.25s;"
          >
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="btn-neon"
            >
              <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4" />
              Hablemos por WhatsApp
            </a>
            <a href="#servicios" class="btn-ghost">
              Ver casos →
            </a>
          </div>
        )}
      </div>

      <!-- Foto compacta con frame glow -->
      <div
        class="hidden lg:block reveal"
        style="transition-delay: 0.9s;"
      >
        <div class="relative">
          <div
            class="relative w-64 h-80 xl:w-72 xl:h-96 overflow-hidden rounded-md border border-white/10"
            style={`background-image: linear-gradient(180deg, transparent 60%, rgba(0,0,0,0.6) 100%), url('${site.professional.photo}'); background-size: cover; background-position: center;`}
            aria-label="Foto de Lucas Contreras"
          ></div>
          <!-- Glow detrás -->
          <span
            class="absolute -inset-2 -z-10 rounded-md blur-2xl bg-accent-500/30"
            aria-hidden="true"
          ></span>
          <!-- Tag flotante "Disponible" -->
          <span
            class="absolute -top-3 -left-3 inline-flex items-center gap-1.5 px-3 py-1.5 bg-night-800 border border-white/10 rounded-full text-[11px] font-semibold text-ink-100 shadow-2xl"
          >
            <span class="relative inline-flex w-1.5 h-1.5">
              <span class="absolute inset-0 rounded-full bg-emerald-500 animate-ping opacity-75"></span>
              <span class="relative rounded-full w-1.5 h-1.5 bg-emerald-500"></span>
            </span>
            Disponible
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
