---
import { site, whatsappUrl, mailtoUrl } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  showCTA?: boolean;
  showContact?: boolean;
}

const {
  eyebrow,
  title,
  subtitle,
  showCTA = true,
  showContact = true,
} = Astro.props;
---

<section class="relative overflow-hidden bg-white pattern-diagonal">
  <div class="grid md:grid-cols-[42%_58%] min-h-[480px] md:min-h-[560px]">
    <!-- Lado izquierdo: texto sobre patrón -->
    <div class="relative flex flex-col justify-between p-8 sm:p-10 md:p-14">
      <div>
        {showContact && (
          <div class="mb-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-navy-700">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center gap-2 hover:text-orange-600 transition-colors"
              aria-label="Escribir por WhatsApp"
            >
              <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4 text-orange-600" />
              <span class="font-semibold tracking-wide">{site.contact.phoneDisplay}</span>
            </a>
            <span class="hidden sm:inline-block w-px h-4 bg-ink-300" aria-hidden="true"></span>
            <a
              href={mailtoUrl("Consulta desde la web")}
              class="group inline-flex items-center gap-2 hover:text-orange-600 transition-colors break-all"
              aria-label="Enviar mail"
            >
              <Icon name="ph:envelope-simple-bold" class="w-4 h-4 text-orange-600 flex-shrink-0" />
              <span class="font-semibold tracking-wide">{site.contact.email}</span>
            </a>
          </div>
        )}
        {eyebrow && (
          <p class="text-xs font-bold tracking-[0.22em] uppercase text-orange-600 mb-4">
            {eyebrow}
          </p>
        )}
        {title && (
          <h1 class="font-display text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-wide uppercase text-navy-700 leading-[1.15]">
            {title}
          </h1>
        )}
        {subtitle && (
          <p class="mt-5 text-ink-500 text-base sm:text-lg max-w-md leading-relaxed">
            {subtitle}
          </p>
        )}

        {showCTA && (
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 px-6 py-3 bg-orange-600 text-white font-bold text-sm tracking-wider uppercase hover:bg-orange-700 transition-colors"
            >
              Consultar
            </a>
            <a
              href="/servicios"
              class="inline-flex items-center gap-2 px-6 py-3 border-2 border-navy-700 text-navy-700 font-bold text-sm tracking-wider uppercase hover:bg-navy-700 hover:text-white transition-colors"
            >
              Servicios
            </a>
          </div>
        )}
      </div>

    </div>

    <!-- Lado derecho: imagen genérica del rubro (banner industrial / herramientas)
         con cortes diagonales que se mezclan con el patrón del hero.
         Para activar imagen: dropear /public/syh-banner.jpg (1200×1200+, vertical
         o cuadrada) y descomentar la capa de fondo.  Hasta que llegue, los cortes
         diagonales sobre el patrón ya forman un hero geométrico válido. -->
    <div class="relative min-h-[300px]">
      <!-- Imagen del rubro (placeholder hasta tener archivo real) -->
      <!--
      <div
        class="absolute inset-0 bg-cover bg-center"
        style="background-image: linear-gradient(135deg, rgba(15,24,73,0.35), rgba(15,24,73,0.15)), url('/syh-banner.jpg');"
      ></div>
      -->

      <!-- Banda blanca de transición desde el lado izquierdo -->
      <div
        class="absolute top-0 bottom-0 left-0 w-[18%] bg-white/85"
        style="clip-path: polygon(0 0, 100% 0, 60% 100%, 0% 100%);"
        aria-hidden="true"
      ></div>

      <!-- Banda navy decorativa -->
      <div
        class="hidden md:block absolute top-0 bottom-0 left-[14%] w-[6%] bg-navy-700/85"
        style="clip-path: polygon(40% 0, 100% 0, 60% 100%, 0% 100%);"
        aria-hidden="true"
      ></div>

      <!-- Banda naranja decorativa -->
      <div
        class="hidden md:block absolute top-0 bottom-0 left-[20%] w-[3%] bg-orange-600/70"
        style="clip-path: polygon(40% 0, 100% 0, 60% 100%, 0% 100%);"
        aria-hidden="true"
      ></div>
    </div>
  </div>
</section>
