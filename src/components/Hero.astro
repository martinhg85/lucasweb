---
import { site, whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  bottomLabel?: string;
  showCTA?: boolean;
  showContact?: boolean;
}

const {
  eyebrow = "Lic. en Seguridad e Higiene · CABA",
  title,
  subtitle,
  showCTA = true,
} = Astro.props;
---

<section class="relative bg-cream-50 overflow-hidden">
  <!-- Halo cobre apenas perceptible -->
  <span
    class="absolute -bottom-32 -right-20 w-[36rem] h-[36rem] rounded-full bg-copper-100/50 blur-3xl pointer-events-none"
    aria-hidden="true"
  ></span>

  <div class="relative container-tight pt-12 pb-16 sm:pt-20 sm:pb-24 md:pt-28 md:pb-32">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-16 items-center">
      <!-- Texto -->
      <div class="max-w-2xl">
        {eyebrow && (
          <div class="flex items-center gap-3 mb-7">
            <span class="inline-block w-8 h-px bg-copper-500" aria-hidden="true"></span>
            <p class="text-[11px] font-semibold tracking-[0.18em] uppercase text-olive-700">
              {eyebrow}
            </p>
          </div>
        )}

        {title && (
          <h1
            class="font-display text-[clamp(2.5rem,6vw,4.75rem)] font-semibold text-ink-900 leading-[1.02] tracking-[-0.03em]"
          >
            {title}
          </h1>
        )}

        {subtitle && (
          <p class="mt-7 text-ink-700 text-lg sm:text-xl leading-relaxed max-w-xl">
            {subtitle}
          </p>
        )}

        {showCTA && (
          <div class="mt-9 flex flex-wrap items-center gap-3">
            <a
              href={whatsappUrl()}
              target="_blank"
              rel="noopener"
              class="btn-primary"
            >
              <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4" />
              Hablemos
            </a>
            <a href="/servicios" class="btn-secondary">
              Ver servicios →
            </a>
          </div>
        )}

        <div class="mt-7 flex items-center gap-2 text-sm text-ink-500">
          <Icon name="ph:hourglass-medium-bold" class="w-4 h-4 text-copper-500" />
          <span class="font-medium">Respuesta en menos de 4 horas</span>
        </div>
      </div>

      <!-- Foto framed -->
      <div class="relative">
        <div class="relative">
          <!-- Marco fino tipo museo / catálogo arquitectónico -->
          <div
            class="relative aspect-[4/5] overflow-hidden bg-ink-200 border border-olive-700"
            style={`background-image: url('${site.professional.photo}'); background-size: cover; background-position: center;`}
            aria-label="Foto de Lucas Contreras"
          >
            <!-- Esquina con número de catálogo -->
            <span
              class="absolute top-4 left-4 text-[10px] font-medium tracking-[0.18em] uppercase text-cream-50 bg-olive-700/80 backdrop-blur-sm px-2 py-1"
            >
              001 · Lucas Contreras
            </span>
            <!-- Marca al pie -->
            <div
              class="absolute bottom-0 left-0 right-0 bg-olive-900/80 backdrop-blur-sm border-t border-cream-50/15 px-5 py-3"
            >
              <p class="text-[10px] font-semibold tracking-widest uppercase text-copper-300">
                Lic. en Seguridad e Higiene
              </p>
              <p class="text-sm font-medium text-cream-50 mt-0.5 leading-tight">
                {site.professional.fullName}
              </p>
            </div>
          </div>

          <!-- Pin cobre decorativo -->
          <span
            class="absolute -top-2 -right-2 w-5 h-5 rounded-full bg-copper-500 ring-4 ring-cream-50 shadow-md"
            aria-hidden="true"
          ></span>
        </div>
      </div>
    </div>
  </div>
</section>
