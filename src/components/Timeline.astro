---
// Trayectoria reverse-chronological estilo Spotlight.
// Datos placeholder mientras Lucas no envíe historial real.
const items = [
  {
    period: "Hoy",
    role: "Asesor independiente",
    org: "Práctica propia · CABA / GBA",
    note: "Habilitaciones, mediciones e incendio para PyMEs y obras civiles.",
  },
  {
    period: "20XX — 20XX",
    role: "[Cargo previo]",
    org: "[Empresa o estudio]",
    note: "[Logro o ámbito principal]",
  },
  {
    period: "20XX",
    role: "Posgrado",
    org: "[Institución]",
    note: "[Especialización en Higiene Ocupacional / Ergonomía / etc.]",
  },
  {
    period: "20XX",
    role: "Lic. en Seguridad e Higiene",
    org: "[Universidad]",
    note: "Matrícula vigente.",
  },
];
---

<section class="bg-cream-50 py-20 sm:py-28">
  <div class="container-tight">
    <div class="grid md:grid-cols-[1fr_2fr] gap-10 md:gap-20">
      <div>
        <p class="section-eyebrow mb-4">Trayectoria</p>
        <h2
          class="font-display font-light text-[clamp(1.875rem,3.5vw,2.75rem)] leading-[1.05] text-ink-900 tracking-tight"
        >
          Quince años cerca de la obra, no del escritorio.
        </h2>
        <p class="mt-5 text-ink-500 leading-relaxed">
          {/* TODO: ajustar narrativa cuando Lucas confirme años y hitos. */}
          De la formación al ejercicio independiente. Cada etapa sumó algo
          distinto al asesoramiento que ofrezco hoy.
        </p>
      </div>

      <ol class="relative border-l border-ink-200 pl-8 space-y-10">
        {items.map((it) => (
          <li class="relative">
            <span
              class="absolute -left-[37px] top-2 w-2.5 h-2.5 rounded-full bg-accent-600 ring-4 ring-cream-50"
              aria-hidden="true"
            ></span>
            <p class="text-xs font-semibold tracking-widest uppercase text-ink-400">
              {it.period}
            </p>
            <p class="mt-2 font-display text-2xl font-medium text-ink-900 tracking-tight">
              {it.role}
            </p>
            <p class="mt-1 text-sm text-ink-700">{it.org}</p>
            {it.note && (
              <p class="mt-3 text-sm text-ink-500 leading-relaxed max-w-md">
                {it.note}
              </p>
            )}
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
