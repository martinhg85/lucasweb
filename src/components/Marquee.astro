---
import { site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  items?: readonly string[];
}

const { items = site.regulations } = Astro.props;

// Para que el loop sea continuo necesitamos duplicar la lista.
// El track entero hace translate -100% y al duplicarlo el viewer no nota el corte.
const doubled = [...items, ...items];
---

<div class="relative bg-night-900 border-y border-white/5 overflow-hidden">
  <div class="marquee py-4">
    <div class="marquee-track text-sm">
      {doubled.map((it, i) => (
        <div class="flex items-center gap-3 text-ink-300 whitespace-nowrap">
          <Icon
            name="ph:shield-check-bold"
            class="w-4 h-4 text-accent-500 flex-shrink-0"
            aria-hidden={i >= items.length}
          />
          <span class="font-medium tracking-wide">{it}</span>
        </div>
      ))}
    </div>
  </div>
</div>
