---
import { clients } from "../data/site";
---

{clients.length > 0 ? (
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-6 max-w-5xl mx-auto">
    {clients.map((c) => (
      <div class="flex items-center justify-center h-28 sm:h-32 px-8 py-5 border border-ink-200 rounded-xl bg-white">
        {c.logo ? (
          <img
            src={c.logo}
            alt={c.name}
            class:list={[
              "max-w-full w-auto opacity-90",
              c.aspect === "square" ? "max-h-20" : "max-h-16",
            ]}
            loading="lazy"
          />
        ) : (
          <span class="text-ink-500 font-semibold tracking-wide text-center text-sm">{c.name}</span>
        )}
      </div>
    ))}
  </div>
) : (
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 sm:gap-6 max-w-5xl mx-auto opacity-50">
    {Array.from({ length: 6 }).map((_, i) => (
      <div class="h-28 sm:h-32 border border-dashed border-ink-300 grid place-items-center text-[10px] text-ink-400 tracking-widest uppercase rounded-xl">
        Logo {i + 1}
      </div>
    ))}
  </div>
)}
