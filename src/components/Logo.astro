---
// Logo custom: casco SyH con stripe naranja integrada en la unión cúpula-visera.
// Color principal heredado por currentColor — el padre setea text-navy-700.
// Stripe naranja hardcoded en var --color-orange-500 para preservar la identidad
// aunque el contenedor cambie de color.

interface Props {
  class?: string;
  title?: string;
}

const { class: className = "", title = "Lucas Contreras — Asesor en Seguridad e Higiene" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 64 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={title}
>
  <title>{title}</title>

  <!-- Visera (brim): más ancha que la cúpula, redondeada -->
  <rect
    x="6"
    y="40"
    width="52"
    height="7"
    rx="3"
    fill="currentColor"
  />

  <!-- Stripe naranja entre cúpula y visera, alineada al ancho de la cúpula -->
  <rect
    x="15"
    y="33"
    width="34"
    height="7"
    fill="var(--color-orange-500)"
  />

  <!-- Cúpula -->
  <path
    d="M 15 33 Q 15 14 32 14 Q 49 14 49 33 Z"
    fill="currentColor"
  />

  <!-- Detalle decorativo: pequeño rib lateral derecho de la cúpula -->
  <path
    d="M 49 24 Q 47 22 47 32"
    stroke="var(--color-orange-500)"
    stroke-width="1.5"
    stroke-linecap="round"
    fill="none"
    opacity="0.55"
  />

  <!-- Línea fina inferior de la visera (sombra) -->
  <line
    x1="9"
    y1="46.5"
    x2="55"
    y2="46.5"
    stroke="currentColor"
    stroke-width="1"
    stroke-linecap="round"
    opacity="0.35"
  />
</svg>
