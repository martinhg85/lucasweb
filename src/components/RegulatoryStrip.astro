---
import { site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  items?: readonly string[];
  label?: string;
}

const { items = site.regulations, label = "Trabajo bajo el marco de" } =
  Astro.props;

const parsed = items.map((raw) => {
  const [name, ...rest] = raw.split(" — ");
  return {
    name: name.trim(),
    description: rest.join(" — ").trim() || undefined,
  };
});
---

<aside
  class="bg-olive-900 text-cream-50 relative overflow-hidden"
  aria-label="Marco normativo"
>
  <span
    class="absolute -top-32 left-1/3 w-[28rem] h-[28rem] rounded-full bg-copper-500/15 blur-3xl pointer-events-none"
    aria-hidden="true"
  ></span>

  <div class="container-tight py-16 sm:py-20 relative reveal">
    <div class="flex items-center justify-center gap-3 mb-6">
      <Icon
        name="ph:shield-check-bold"
        class="w-6 h-6 text-copper-300"
        aria-hidden="true"
      />
      <p class="text-[11px] font-semibold tracking-[0.22em] uppercase text-copper-300">
        {label}
      </p>
    </div>

    <div class="mx-auto max-w-md border-t border-cream-50/15 mb-12"></div>

    <ul
      class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-10 max-w-5xl mx-auto"
    >
      {parsed.map((r) => (
        <li class="text-center">
          <p class="font-display text-sm sm:text-base font-semibold tracking-tight leading-tight">
            {r.name}
          </p>
          {r.description && (
            <p class="mt-2 text-xs text-cream-50/70 leading-relaxed">
              {r.description}
            </p>
          )}
        </li>
      ))}
    </ul>
  </div>
</aside>
