---
import { site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  // Si se pasan, sobreescribe la lista global. Útil en páginas de servicios.
  items?: readonly string[];
  label?: string;
}

const { items = site.regulations, label = "Trabajo bajo el marco de" } =
  Astro.props;
---

<aside
  class="bg-navy-700 text-white relative overflow-hidden"
  aria-label="Marco normativo"
>
  <div class="absolute inset-0 pattern-diagonal-light opacity-40"></div>
  <div class="container-tight py-8 sm:py-10 relative">
    <div class="flex flex-col md:flex-row md:items-center gap-5 md:gap-8">
      <div class="flex items-center gap-3 flex-shrink-0">
        <Icon
          name="ph:scales-bold"
          class="w-6 h-6 text-orange-500"
          aria-hidden="true"
        />
        <p class="text-[11px] font-bold tracking-[0.22em] uppercase text-orange-500">
          {label}
        </p>
      </div>

      <ul class="flex flex-wrap gap-x-6 gap-y-2 text-xs sm:text-sm text-white/90">
        {items.map((r) => (
          <li class="flex items-center gap-2">
            <span
              class="inline-block w-1.5 h-1.5 bg-orange-500 flex-shrink-0"
              aria-hidden="true"
            ></span>
            <span class="font-medium tracking-wide">{r}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</aside>
