---
import { site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  items?: readonly string[];
  label?: string;
}

const { items = site.regulations, label = "Trabajo bajo el marco de" } =
  Astro.props;

const parsed = items.map((raw) => {
  const [name, ...rest] = raw.split(" — ");
  return {
    name: name.trim(),
    description: rest.join(" — ").trim() || undefined,
  };
});
---

<aside
  class="relative bg-night-950 text-white overflow-hidden border-y border-white/5"
  aria-label="Marco normativo"
>
  <span
    class="absolute -top-32 right-1/3 w-[32rem] h-[32rem] glow-orange opacity-25"
    aria-hidden="true"
  ></span>
  <div class="absolute inset-0 pattern-diagonal-light pointer-events-none"></div>

  <div class="container-tight py-16 sm:py-20 relative reveal">
    <div class="flex items-center justify-center gap-3 mb-6">
      <Icon
        name="ph:shield-check-bold"
        class="w-6 h-6 text-orange-400"
        aria-hidden="true"
      />
      <p class="text-[11px] font-bold tracking-[0.22em] uppercase text-orange-400">
        {label}
      </p>
    </div>

    <div class="mx-auto max-w-md border-t border-white/15 mb-12"></div>

    <ul
      class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-10 max-w-5xl mx-auto"
    >
      {parsed.map((r) => (
        <li class="text-center">
          <p class="font-display text-sm sm:text-base font-bold tracking-tight uppercase text-ink-50 leading-tight">
            {r.name}
          </p>
          {r.description && (
            <p class="mt-2 text-xs text-ink-300 leading-relaxed">
              {r.description}
            </p>
          )}
        </li>
      ))}
    </ul>
  </div>
</aside>
