---
import { site } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  // Si se pasan, sobreescribe la lista global. Útil en páginas de servicios.
  items?: readonly string[];
  label?: string;
}

const { items = site.regulations, label = "Trabajo bajo el marco de" } =
  Astro.props;

// Cada string viene como "Nombre corto — Descripción". Separamos para mostrar
// el nombre como título y la descripción como subtítulo en cada celda del grid.
const parsed = items.map((raw) => {
  const [name, ...rest] = raw.split(" — ");
  return {
    name: name.trim(),
    description: rest.join(" — ").trim() || undefined,
  };
});
---

<aside
  class="bg-navy-700 text-white relative overflow-hidden"
  aria-label="Marco normativo"
>
  <div class="absolute inset-0 pattern-diagonal-light opacity-40"></div>

  <div class="container-tight py-14 sm:py-16 relative">
    <!-- Encabezado centrado: ícono + eyebrow -->
    <div class="flex items-center justify-center gap-3 mb-6">
      <Icon
        name="ph:shield-check-bold"
        class="w-6 h-6 text-orange-500"
        aria-hidden="true"
      />
      <p class="text-[11px] font-bold tracking-[0.22em] uppercase text-orange-500">
        {label}
      </p>
    </div>

    <!-- Línea divisoria suave -->
    <div class="mx-auto max-w-md border-t border-white/15 mb-12"></div>

    <!-- Grid 3x2 simétrico -->
    <ul
      class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-10 max-w-5xl mx-auto"
    >
      {parsed.map((r) => (
        <li class="text-center">
          <p class="font-display text-sm sm:text-base font-bold tracking-wide uppercase text-white leading-tight">
            {r.name}
          </p>
          {r.description && (
            <p class="mt-2 text-xs text-white/70 leading-relaxed">
              {r.description}
            </p>
          )}
        </li>
      ))}
    </ul>
  </div>
</aside>
