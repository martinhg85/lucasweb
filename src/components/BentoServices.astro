---
import { services } from "../data/site";
import { Icon } from "astro-icon/components";

const icons: Record<string, string> = {
  habilitaciones: "ph:buildings-bold",
  mediciones: "ph:gauge-bold",
  incendios: "ph:fire-extinguisher-bold",
};

// Encontramos el highlight (mediciones) y los otros dos
const highlight = services.find((s) => s.highlight) ?? services[0];
const rest = services.filter((s) => s.slug !== highlight.slug);
---

<section
  id="servicios"
  class="relative bg-night-900 py-24 sm:py-32 overflow-hidden"
>
  <span
    class="orb orb-amber w-[36rem] h-[36rem]"
    style="top:30%; right:-12rem; opacity:0.25;"
    aria-hidden="true"
  ></span>

  <div class="container-tight relative">
    <div class="max-w-3xl mb-16 reveal">
      <p class="section-eyebrow mb-5">Servicios</p>
      <h2
        class="font-display font-bold text-ink-50 leading-[0.95] tracking-tight"
        style="font-size: clamp(2.5rem, 5.5vw, 4.5rem);"
      >
        Tres áreas.<br />
        <span class="text-accent-500">Una sola firma.</span>
      </h2>
      <p class="mt-6 text-lg text-ink-400 max-w-xl">
        Atención personal en CABA y GBA. Sin intermediarios entre vos y el que firma el protocolo.
      </p>
    </div>

    <!-- Bento: 1 grande (highlight) + 2 chicas en columna -->
    <div class="grid lg:grid-cols-[1.6fr_1fr] gap-5 reveal-stagger">
      <!-- HIGHLIGHT -->
      <a
        href={`/servicios/${highlight.slug}`}
        class="tilt-card group relative bg-night-800 border border-white/10 rounded-2xl p-8 sm:p-10 overflow-hidden hover:border-white/20 transition-colors min-h-[28rem] flex flex-col justify-between"
      >
        <span class="tilt-card-glow rounded-2xl"></span>

        <!-- Pattern + Glow -->
        <div
          class="absolute inset-0 opacity-50 pattern-diagonal pointer-events-none"
        ></div>
        <span
          class="absolute -top-20 -right-20 w-72 h-72 rounded-full blur-3xl bg-accent-600/30 pointer-events-none"
          aria-hidden="true"
        ></span>

        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-6">
            <span
              class="inline-grid place-items-center w-12 h-12 rounded-full bg-accent-500/15 text-accent-500 ring-1 ring-accent-500/30"
            >
              <Icon
                name={icons[highlight.slug] ?? icons.mediciones}
                class="w-6 h-6"
              />
            </span>
            <p class="section-eyebrow">Especialidad</p>
          </div>
          <h3
            class="font-display font-bold text-ink-50 tracking-tight leading-[0.95]"
            style="font-size: clamp(2rem, 4vw, 3.25rem);"
          >
            {highlight.title}
          </h3>
          <p class="mt-5 text-ink-300 max-w-md leading-relaxed">
            {highlight.short}
          </p>
        </div>

        <div class="relative z-10 mt-10">
          <ul class="grid grid-cols-2 gap-x-5 gap-y-2 text-sm text-ink-400">
            {highlight.items.slice(0, 6).map((it) => (
              <li class="flex items-start gap-2">
                <span class="text-accent-500 mt-1">—</span>
                <span>{it}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-accent-400 group-hover:gap-4 transition-all">
            Ver el detalle completo →
          </div>
        </div>
      </a>

      <!-- 2 cards laterales en columna -->
      <div class="grid grid-rows-2 gap-5">
        {rest.map((s) => (
          <a
            href={`/servicios/${s.slug}`}
            class="tilt-card group relative bg-night-800 border border-white/10 rounded-2xl p-7 overflow-hidden hover:border-white/20 transition-colors flex flex-col justify-between"
          >
            <span class="tilt-card-glow rounded-2xl"></span>

            <div
              class="absolute inset-0 opacity-30 pattern-diagonal pointer-events-none"
            ></div>

            <div class="relative z-10">
              <span
                class="inline-grid place-items-center w-10 h-10 rounded-full bg-night-700 text-ink-100 ring-1 ring-white/10 group-hover:bg-accent-500/15 group-hover:text-accent-500 group-hover:ring-accent-500/30 transition-colors"
              >
                <Icon
                  name={icons[s.slug] ?? icons.habilitaciones}
                  class="w-5 h-5"
                />
              </span>

              <h3 class="mt-5 font-display font-bold text-ink-50 text-2xl tracking-tight leading-tight">
                {s.title}
              </h3>
              <p class="mt-3 text-sm text-ink-400 leading-relaxed">
                {s.short}
              </p>
            </div>

            <div class="relative z-10 mt-5 flex items-center justify-between">
              {s.regulations && s.regulations.length > 0 && (
                <p class="text-[11px] text-ink-500 font-medium tracking-wide">
                  {s.regulations[0]}
                </p>
              )}
              <span class="text-xs font-bold text-accent-400 group-hover:translate-x-1 transition-transform">
                Ver →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
