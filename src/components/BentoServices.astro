---
import { services } from "../data/site";
import { Icon } from "astro-icon/components";
import SectionTitle from "./SectionTitle.astro";

const icons: Record<string, string> = {
  habilitaciones: "ph:buildings-bold",
  mediciones: "ph:gauge-bold",
  incendios: "ph:fire-extinguisher-bold",
};

const highlight = services.find((s) => s.highlight) ?? services[0];
const rest = services.filter((s) => s.slug !== highlight.slug);
---

<section
  id="servicios"
  class="relative bg-night-900 py-24 sm:py-32 overflow-hidden"
>
  <span
    class="absolute top-1/3 -right-32 w-[28rem] h-[28rem] glow-orange opacity-50"
    aria-hidden="true"
  ></span>

  <div class="container-tight relative">
    <SectionTitle
      eyebrow="Servicios"
      title="Tres áreas, una sola firma"
      subtitle="Atención personal en CABA y GBA. Sin intermediarios entre vos y el que firma el protocolo."
    />

    <!-- Bento: highlight grande + 2 chicas -->
    <div class="grid lg:grid-cols-[1.5fr_1fr] gap-5 reveal-stagger">
      <!-- Highlight -->
      <a
        href={`/servicios/${highlight.slug}`}
        class="card-dark group block p-7 sm:p-9 overflow-hidden min-h-[26rem] flex flex-col justify-between"
      >
        <span
          class="absolute -top-20 -right-20 w-72 h-72 glow-orange opacity-60 pointer-events-none"
          aria-hidden="true"
        ></span>
        <div class="absolute inset-0 pattern-diagonal pointer-events-none"></div>

        <div class="relative z-10">
          <div class="flex items-center gap-3 mb-6">
            <span
              class="grid place-items-center w-12 h-12 rounded-xl bg-orange-500/15 text-orange-400 ring-1 ring-orange-500/30"
            >
              <Icon
                name={icons[highlight.slug] ?? icons.mediciones}
                class="w-6 h-6"
              />
            </span>
            <p class="text-[10px] font-bold tracking-[0.22em] uppercase text-orange-400">
              Especialidad
            </p>
          </div>

          <h3 class="font-display font-extrabold text-ink-50 text-3xl sm:text-4xl tracking-tight leading-[1.05]">
            {highlight.title}
          </h3>
          <p class="mt-4 text-ink-300 max-w-md leading-relaxed">
            {highlight.short}
          </p>
        </div>

        <div class="relative z-10 mt-8">
          <ul class="grid grid-cols-2 gap-x-5 gap-y-2 text-sm text-ink-300">
            {highlight.items.slice(0, 6).map((it) => (
              <li class="flex items-start gap-2">
                <Icon
                  name="ph:check-bold"
                  class="w-4 h-4 text-orange-400 mt-0.5 flex-shrink-0"
                />
                <span>{it}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-orange-400 group-hover:gap-4 transition-all">
            Ver el detalle completo →
          </div>
        </div>
      </a>

      <!-- 2 cards en columna -->
      <div class="grid grid-rows-2 gap-5">
        {rest.map((s) => (
          <a
            href={`/servicios/${s.slug}`}
            class="card-dark group block p-7 overflow-hidden flex flex-col justify-between"
          >
            <div class="absolute inset-0 pattern-diagonal opacity-50 pointer-events-none"></div>

            <div class="relative z-10">
              <span
                class="grid place-items-center w-10 h-10 rounded-xl bg-night-700 text-ink-200 ring-1 ring-white/10 group-hover:bg-orange-500/15 group-hover:text-orange-400 group-hover:ring-orange-500/30 transition-colors"
              >
                <Icon
                  name={icons[s.slug] ?? icons.habilitaciones}
                  class="w-5 h-5"
                />
              </span>

              <h3 class="mt-5 font-display font-bold text-ink-50 text-xl sm:text-2xl tracking-tight leading-tight">
                {s.title}
              </h3>
              <p class="mt-3 text-sm text-ink-400 leading-relaxed">
                {s.short}
              </p>
            </div>

            <div class="relative z-10 mt-5 flex items-center justify-between">
              {s.regulations && s.regulations.length > 0 && (
                <p class="text-[11px] text-ink-500 font-medium tracking-wide truncate">
                  {s.regulations[0]}
                </p>
              )}
              <span class="text-xs font-bold text-orange-400 group-hover:translate-x-1 transition-transform shrink-0">
                Ver →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
