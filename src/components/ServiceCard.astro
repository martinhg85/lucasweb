---
import type { ServiceGroup } from "../data/site";

interface Props {
  service: ServiceGroup;
  index?: number;
}

const { service, index = 0 } = Astro.props;
const href = `/servicios/${service.slug}`;
---

<a href={href} class="card-frame group block p-7 sm:p-8 h-full">
  <p class="num-badge text-[11px] tracking-[0.22em] uppercase mb-4">
    {String(index + 1).padStart(3, "0")}
  </p>
  <h3 class="font-display text-xl sm:text-2xl font-semibold text-ink-900 leading-tight tracking-tight">
    {service.title}
  </h3>
  <div class="mt-3 mb-5 h-px w-12 bg-copper-500"></div>
  <p class="text-ink-500 text-sm leading-relaxed">
    {service.short}
  </p>

  {service.regulations && service.regulations.length > 0 && (
    <ul class="mt-5 flex flex-wrap gap-x-3 gap-y-1 text-[11px] text-ink-400">
      {service.regulations.slice(0, 3).map((r) => (
        <li class="flex items-center gap-1.5">
          <span class="inline-block w-1 h-1 bg-olive-700" aria-hidden="true"></span>
          <span class="font-medium tracking-wide">{r}</span>
        </li>
      ))}
    </ul>
  )}

  <p class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-olive-700 group-hover:gap-3 transition-all">
    Ver detalle
    <span aria-hidden="true">→</span>
  </p>
</a>
