---
import type { ServiceGroup } from "../data/site";
import { Icon } from "astro-icon/components";

interface Props {
  service: ServiceGroup;
}

const { service } = Astro.props;
const href = `/servicios/${service.slug}`;

const icons: Record<string, string> = {
  habilitaciones: "ph:buildings-bold",
  mediciones: "ph:gauge-bold",
  incendios: "ph:fire-extinguisher-bold",
};
---

<a href={href} class="group card-soft block p-7 sm:p-8 h-full">
  <span
    class="grid place-items-center w-12 h-12 rounded-2xl bg-sky-50 text-sky-600 mb-5 group-hover:bg-sky-100 transition-colors"
  >
    <Icon
      name={icons[service.slug] ?? "ph:briefcase-bold"}
      class="w-6 h-6"
    />
  </span>

  <h3 class="font-bold text-ink-900 text-lg sm:text-xl leading-tight">
    {service.title}
  </h3>

  <p class="mt-3 text-ink-500 text-sm leading-relaxed">
    {service.short}
  </p>

  {service.regulations && service.regulations.length > 0 && (
    <ul class="mt-5 flex flex-wrap gap-x-3 gap-y-1 text-[11px] text-ink-400">
      {service.regulations.slice(0, 3).map((r) => (
        <li class="flex items-center gap-1.5">
          <span class="inline-block w-1 h-1 rounded-full bg-sky-500" aria-hidden="true"></span>
          <span class="font-medium tracking-wide">{r}</span>
        </li>
      ))}
    </ul>
  )}

  <p class="mt-6 inline-flex items-center gap-1.5 text-sm font-bold text-sky-600 group-hover:gap-3 transition-all">
    Ver detalle
    <span aria-hidden="true">→</span>
  </p>
</a>
