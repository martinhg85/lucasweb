---
import { site, navLinks, whatsappUrl } from "../data/site";
import { Icon } from "astro-icon/components";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === path || (href !== "/" && path.startsWith(href));
---

<header
  id="site-header"
  class="site-header fixed top-0 left-0 right-0 z-40 border-b border-transparent"
>
  <div
    class="header-inner container-tight grid grid-cols-[auto_1fr_auto] md:grid-cols-[auto_1fr_auto] items-center gap-4"
  >
    <!-- Logo + tagline -->
    <a
      href="/"
      class="header-brand-link flex items-center gap-3 group"
      aria-label={site.name}
    >
      <span
        class="header-logo grid place-items-center rounded-2xl bg-gradient-to-br from-orange-500 to-orange-600 text-white flex-shrink-0 shadow-lg shadow-orange-500/40"
      >
        <Icon name="ph:hard-hat-bold" class="w-5 h-5" aria-hidden="true" />
      </span>
      <div class="leading-none min-w-0">
        <p class="header-brand font-bold tracking-tight text-ink-50 truncate">
          Lucas Contreras
        </p>
        <p class="header-tagline font-medium tracking-wide text-ink-300 truncate">
          {site.brandTagline}
        </p>
      </div>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:block md:justify-self-center">
      <ul class="flex items-center gap-1 text-sm font-semibold text-ink-200">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "header-link block rounded-full whitespace-nowrap transition-colors",
                isActive(l.href)
                  ? "text-orange-400 bg-white/5"
                  : "hover:text-ink-50",
              ]}
            >
              {l.label.charAt(0) + l.label.slice(1).toLowerCase()}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-2 md:justify-self-end">
      <a
        href={whatsappUrl()}
        target="_blank"
        rel="noopener"
        class="hidden md:inline-flex items-center gap-2 px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white text-sm font-bold rounded-full shadow-lg shadow-orange-500/30 transition-colors"
      >
        <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4" />
        Consultar
      </a>

      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden inline-grid place-items-center w-11 h-11 rounded-xl text-ink-100 hover:bg-white/5 transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
      >
        <svg
          class="hamburger-icon w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line class="line-top" x1="4" y1="7" x2="20" y2="7"></line>
          <line class="line-mid" x1="4" y1="12" x2="20" y2="12"></line>
          <line class="line-bot" x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </button>
    </div>
  </div>
</header>
<div id="header-spacer" class="header-spacer" aria-hidden="true"></div>

<!-- Mobile menu panel -->
<div
  id="mobile-menu-panel"
  class="mobile-menu fixed inset-0 z-50 md:hidden"
  aria-hidden="true"
>
  <div class="mobile-menu-overlay absolute inset-0 bg-night-950/70 backdrop-blur-sm"></div>
  <aside
    class="mobile-menu-drawer absolute top-0 right-0 bottom-0 w-[85%] max-w-sm bg-night-900 shadow-2xl flex flex-col border-l border-white/10"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
  >
    <div class="flex items-center justify-between px-5 py-4 border-b border-white/10">
      <p class="font-bold text-lg text-ink-50 tracking-tight">Menú</p>
      <button
        id="mobile-menu-close"
        type="button"
        class="inline-grid place-items-center w-10 h-10 rounded-xl text-ink-100 hover:bg-white/5 transition-colors"
        aria-label="Cerrar menú"
      >
        <svg
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="18" y1="6" x2="6" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto p-2">
      <ul class="flex flex-col">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "block px-4 py-4 text-base font-semibold rounded-xl transition-colors",
                isActive(l.href)
                  ? "bg-white/5 text-orange-400"
                  : "text-ink-200 hover:bg-white/5 hover:text-ink-50",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="p-4 border-t border-white/10">
      <a
        href={whatsappUrl()}
        target="_blank"
        rel="noopener"
        class="btn-primary w-full"
      >
        <Icon name="ph:whatsapp-logo-bold" class="w-4 h-4" />
        Consultar por WhatsApp
      </a>
    </div>
  </aside>
</div>

<style>
  .mobile-menu {
    pointer-events: none;
    visibility: hidden;
  }
  .mobile-menu.is-open {
    pointer-events: auto;
    visibility: visible;
  }
  .mobile-menu-overlay {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .mobile-menu.is-open .mobile-menu-overlay {
    opacity: 1;
  }
  .mobile-menu-drawer {
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-menu.is-open .mobile-menu-drawer {
    transform: translateX(0);
  }
  body.menu-open {
    overflow: hidden;
  }
  .hamburger-icon line {
    transition: transform 0.3s ease, opacity 0.2s ease;
    transform-origin: center;
  }
  #mobile-menu-btn[aria-expanded="true"] .line-top {
    transform: translate(0, 5px) rotate(45deg);
  }
  #mobile-menu-btn[aria-expanded="true"] .line-mid {
    opacity: 0;
  }
  #mobile-menu-btn[aria-expanded="true"] .line-bot {
    transform: translate(0, -5px) rotate(-45deg);
  }
</style>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    if (!header) return;
    const enterAt = 60;
    const exitAt = 24;
    let scrolled = false;
    const update = () => {
      const y = window.scrollY;
      let next = scrolled;
      if (!scrolled && y > enterAt) next = true;
      else if (scrolled && y < exitAt) next = false;
      if (next !== scrolled) {
        scrolled = next;
        header.classList.toggle("is-scrolled", scrolled);
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  })();

  // Reveal on scroll — DOMContentLoaded para asegurar que el body esté parseado
  function setupReveal() {
    const targets = document.querySelectorAll(".reveal, .reveal-stagger");
    if (!targets.length) return;
    if (!("IntersectionObserver" in window)) {
      targets.forEach((t) => t.classList.add("is-visible"));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        });
      },
      { rootMargin: "0px 0px -8% 0px", threshold: 0.1 }
    );
    targets.forEach((t) => io.observe(t));
    setTimeout(() => {
      targets.forEach((t) => t.classList.add("is-visible"));
    }, 2000);
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupReveal);
  } else {
    setupReveal();
  }

  // Mobile menu toggle
  function setupMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const panel = document.getElementById("mobile-menu-panel");
    const closeBtn = document.getElementById("mobile-menu-close");
    if (!btn || !panel) return;
    const overlay = panel.querySelector(".mobile-menu-overlay");
    const links = panel.querySelectorAll("a");
    const open = () => {
      panel.classList.add("is-open");
      panel.setAttribute("aria-hidden", "false");
      btn.setAttribute("aria-expanded", "true");
      btn.setAttribute("aria-label", "Cerrar menú");
      document.body.classList.add("menu-open");
    };
    const close = () => {
      panel.classList.remove("is-open");
      panel.setAttribute("aria-hidden", "true");
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Abrir menú");
      document.body.classList.remove("menu-open");
    };
    btn.addEventListener("click", () => {
      panel.classList.contains("is-open") ? close() : open();
    });
    closeBtn?.addEventListener("click", close);
    overlay?.addEventListener("click", close);
    links.forEach((a) => a.addEventListener("click", close));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && panel.classList.contains("is-open")) close();
    });
    const mq = window.matchMedia("(min-width: 768px)");
    mq.addEventListener("change", (e) => {
      if (e.matches) close();
    });
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupMobileMenu);
  } else {
    setupMobileMenu();
  }
</script>
