---
import { site, navLinks } from "../data/site";
const path = Astro.url.pathname;
const isActive = (href: string) => href === path || (href !== "/" && path.startsWith(href));
---

<header
  id="site-header"
  class="site-header fixed top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-sm border-b border-ink-200"
>
  <div class="header-inner container-tight grid grid-cols-1 md:grid-cols-[auto_1fr] items-end gap-6">
    <!-- Logo + tagline -->
    <a href="/" class="header-brand-link flex items-center gap-3 group" aria-label={site.name}>
      <span class="header-logo relative inline-grid place-items-center rounded-full border-[3px] border-navy-700">
        <span class="absolute inset-1.5 rounded-full bg-ink-200"></span>
        <span class="relative w-3 h-3 rounded-full bg-orange-600 -translate-y-0.5"></span>
        <span class="absolute bottom-1.5 w-7 h-1.5 bg-navy-700 rounded-sm"></span>
      </span>
      <div class="leading-none">
        <p class="header-brand font-display font-extrabold tracking-wider text-navy-700">
          {site.name.toUpperCase()}
        </p>
        <p class="header-tagline font-semibold tracking-[0.18em] uppercase text-orange-600">
          {site.brandTagline}
        </p>
      </div>
    </a>

    <!-- Nav -->
    <nav class="md:justify-self-end overflow-x-auto">
      <ul class="flex items-stretch gap-0 text-sm font-semibold text-navy-700">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "header-link block px-4 sm:px-5 transition-colors tracking-wider whitespace-nowrap",
                isActive(l.href)
                  ? "bg-navy-700 text-white"
                  : "hover:text-orange-600",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
<!-- Spacer: ocupa el alto del header inicial para que el contenido no quede oculto.
     No cambia cuando el header se compacta, así no hay reflow al scrollear. -->
<div id="header-spacer" class="header-spacer" aria-hidden="true"></div>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    const spacer = document.getElementById("header-spacer");
    if (!header || !spacer) return;

    // Medir el alto natural del header (sin "is-scrolled") y fijarlo en el spacer.
    // Se vuelve a medir en resize para responder a cambios de breakpoint.
    const measure = () => {
      const wasScrolled = header.classList.contains("is-scrolled");
      if (wasScrolled) header.classList.remove("is-scrolled");
      spacer.style.height = header.offsetHeight + "px";
      if (wasScrolled) header.classList.add("is-scrolled");
    };

    // Histéresis: agrega "is-scrolled" pasando 80px, lo quita debajo de 24px.
    // Evita que el usuario quede oscilando entre estados al pararse en el medio.
    const enterAt = 80;
    const exitAt = 24;
    let scrolled = false;
    const update = () => {
      const y = window.scrollY;
      let next = scrolled;
      if (!scrolled && y > enterAt) next = true;
      else if (scrolled && y < exitAt) next = false;
      if (next !== scrolled) {
        scrolled = next;
        header.classList.toggle("is-scrolled", scrolled);
      }
    };

    measure();
    update();
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", measure);
  })();
</script>
