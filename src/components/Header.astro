---
import { site, navLinks } from "../data/site";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === path || (href !== "/" && path.startsWith(href));
---

<header
  id="site-header"
  class="site-header fixed top-0 left-0 right-0 z-40 border-b border-transparent"
>
  <div
    class="header-inner container-tight grid grid-cols-1 md:grid-cols-[auto_1fr] items-center gap-6"
  >
    <!-- Logo: monograma minimal -->
    <a
      href="/"
      class="header-brand-link flex items-center gap-3 group"
      aria-label={site.name}
    >
      <span
        class="header-logo grid place-items-center rounded-full bg-accent-500 text-night-900 group-hover:scale-110 transition-transform"
      >
        <span class="font-display text-base font-bold tracking-tight">LC</span>
      </span>
      <div class="leading-none">
        <p class="header-brand font-display font-bold text-ink-50 tracking-tight">
          Lucas Contreras
        </p>
        <p class="header-tagline font-medium tracking-widest uppercase text-ink-400">
          {site.brandTagline}
        </p>
      </div>
    </a>

    <!-- Nav -->
    <nav class="md:justify-self-end overflow-x-auto">
      <ul class="flex items-center gap-1 text-sm font-medium text-ink-300">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "header-link block rounded-full whitespace-nowrap transition-colors",
                isActive(l.href)
                  ? "text-accent-500 bg-white/5"
                  : "hover:text-ink-50",
              ]}
            >
              {l.label.charAt(0) + l.label.slice(1).toLowerCase()}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
<div id="header-spacer" class="header-spacer" aria-hidden="true"></div>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    if (!header) return;
    const enterAt = 60;
    const exitAt = 24;
    let scrolled = false;
    const update = () => {
      const y = window.scrollY;
      let next = scrolled;
      if (!scrolled && y > enterAt) next = true;
      else if (scrolled && y < exitAt) next = false;
      if (next !== scrolled) {
        scrolled = next;
        header.classList.toggle("is-scrolled", scrolled);
      }
    };
    update();
    window.addEventListener("scroll", update, { passive: true });
  })();

  // Reveal on scroll: agrega .is-visible a elementos con .reveal o .reveal-stagger
  (function () {
    const targets = document.querySelectorAll(".reveal, .reveal-stagger");
    if (!("IntersectionObserver" in window)) {
      targets.forEach((t) => t.classList.add("is-visible"));
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("is-visible");
            io.unobserve(e.target);
          }
        });
      },
      { rootMargin: "0px 0px -10% 0px", threshold: 0.1 }
    );
    targets.forEach((t) => io.observe(t));
  })();
</script>
