---
import { site, navLinks } from "../data/site";
import Logo from "./Logo.astro";
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === path || (href !== "/" && path.startsWith(href));
---

<header
  id="site-header"
  class="site-header fixed top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-sm border-b border-ink-200"
>
  <div
    class="header-inner container-tight grid grid-cols-[auto_1fr_auto] md:grid-cols-[auto_1fr] items-center gap-4 md:items-end md:gap-6"
  >
    <!-- Logo + tagline -->
    <a
      href="/"
      class="header-brand-link flex items-center gap-3 group"
      aria-label={site.name}
    >
      <span class="header-logo grid place-items-center text-navy-700 flex-shrink-0">
        <Logo class="w-full h-full" title={site.name} />
      </span>
      <div class="leading-none min-w-0">
        <p class="header-brand font-display font-extrabold tracking-tight text-navy-700 truncate">
          {site.name}
        </p>
        <p class="header-tagline font-medium text-orange-600 truncate">
          {site.brandTagline}
        </p>
      </div>
    </a>

    <!-- Nav desktop -->
    <nav class="hidden md:block md:justify-self-end">
      <ul class="flex items-stretch gap-0 text-sm font-semibold text-navy-700">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "header-link block px-4 sm:px-5 transition-colors tracking-wider whitespace-nowrap",
                isActive(l.href)
                  ? "bg-navy-700 text-white"
                  : "hover:text-orange-600",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hamburger mobile -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="md:hidden inline-grid place-items-center w-11 h-11 rounded-md text-navy-700 hover:bg-ink-100 transition-colors"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu-panel"
    >
      <svg
        class="hamburger-icon w-6 h-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line class="line-top" x1="4" y1="7" x2="20" y2="7"></line>
        <line class="line-mid" x1="4" y1="12" x2="20" y2="12"></line>
        <line class="line-bot" x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>
  </div>
</header>
<div id="header-spacer" class="header-spacer" aria-hidden="true"></div>

<!-- Mobile menu panel -->
<div
  id="mobile-menu-panel"
  class="mobile-menu fixed inset-0 z-50 md:hidden"
  aria-hidden="true"
>
  <div class="mobile-menu-overlay absolute inset-0 bg-navy-900/60 backdrop-blur-sm"></div>
  <aside
    class="mobile-menu-drawer absolute top-0 right-0 bottom-0 w-[85%] max-w-sm bg-white shadow-2xl flex flex-col"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación"
  >
    <div class="flex items-center justify-between px-5 py-4 border-b border-ink-200">
      <p class="font-display font-extrabold text-lg tracking-wider text-navy-700">
        Menú
      </p>
      <button
        id="mobile-menu-close"
        type="button"
        class="inline-grid place-items-center w-10 h-10 rounded-md text-navy-700 hover:bg-ink-100 transition-colors"
        aria-label="Cerrar menú"
      >
        <svg
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="18" y1="6" x2="6" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto p-2">
      <ul class="flex flex-col">
        {navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "block px-4 py-4 text-base font-semibold tracking-wider rounded-md transition-colors",
                isActive(l.href)
                  ? "bg-navy-700 text-white"
                  : "text-navy-700 hover:bg-ink-100 hover:text-orange-600",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="px-5 py-5 border-t border-ink-200 text-xs text-ink-500">
      {site.brandTagline}
    </div>
  </aside>
</div>

<style>
  .mobile-menu {
    pointer-events: none;
    visibility: hidden;
  }
  .mobile-menu.is-open {
    pointer-events: auto;
    visibility: visible;
  }
  .mobile-menu-overlay {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .mobile-menu.is-open .mobile-menu-overlay {
    opacity: 1;
  }
  .mobile-menu-drawer {
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-menu.is-open .mobile-menu-drawer {
    transform: translateX(0);
  }
  body.menu-open {
    overflow: hidden;
  }
  /* Hamburger to X */
  .hamburger-icon line {
    transition:
      transform 0.3s ease,
      opacity 0.2s ease;
    transform-origin: center;
  }
  #mobile-menu-btn[aria-expanded="true"] .line-top {
    transform: translate(0, 5px) rotate(45deg);
  }
  #mobile-menu-btn[aria-expanded="true"] .line-mid {
    opacity: 0;
  }
  #mobile-menu-btn[aria-expanded="true"] .line-bot {
    transform: translate(0, -5px) rotate(-45deg);
  }
</style>

<script is:inline>
  (function () {
    const header = document.getElementById("site-header");
    const spacer = document.getElementById("header-spacer");
    if (!header || !spacer) return;

    const measure = () => {
      const wasScrolled = header.classList.contains("is-scrolled");
      if (wasScrolled) header.classList.remove("is-scrolled");
      spacer.style.height = header.offsetHeight + "px";
      if (wasScrolled) header.classList.add("is-scrolled");
    };

    const enterAt = 80;
    const exitAt = 24;
    let scrolled = false;
    const update = () => {
      const y = window.scrollY;
      let next = scrolled;
      if (!scrolled && y > enterAt) next = true;
      else if (scrolled && y < exitAt) next = false;
      if (next !== scrolled) {
        scrolled = next;
        header.classList.toggle("is-scrolled", scrolled);
      }
    };

    measure();
    update();
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", measure);
  })();

  // Mobile menu toggle
  (function () {
    const btn = document.getElementById("mobile-menu-btn");
    const panel = document.getElementById("mobile-menu-panel");
    const closeBtn = document.getElementById("mobile-menu-close");
    if (!btn || !panel) return;

    const overlay = panel.querySelector(".mobile-menu-overlay");
    const links = panel.querySelectorAll("a");

    const open = () => {
      panel.classList.add("is-open");
      panel.setAttribute("aria-hidden", "false");
      btn.setAttribute("aria-expanded", "true");
      btn.setAttribute("aria-label", "Cerrar menú");
      document.body.classList.add("menu-open");
    };
    const close = () => {
      panel.classList.remove("is-open");
      panel.setAttribute("aria-hidden", "true");
      btn.setAttribute("aria-expanded", "false");
      btn.setAttribute("aria-label", "Abrir menú");
      document.body.classList.remove("menu-open");
    };
    const toggle = () => {
      if (panel.classList.contains("is-open")) close();
      else open();
    };

    btn.addEventListener("click", toggle);
    closeBtn?.addEventListener("click", close);
    overlay?.addEventListener("click", close);
    links.forEach((a) => a.addEventListener("click", close));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && panel.classList.contains("is-open")) close();
    });
    // Cierra el drawer si se cruza al breakpoint desktop
    const mq = window.matchMedia("(min-width: 768px)");
    mq.addEventListener("change", (e) => {
      if (e.matches) close();
    });
  })();
</script>
